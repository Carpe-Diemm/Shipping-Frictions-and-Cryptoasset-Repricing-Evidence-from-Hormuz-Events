def _compute_car(win: pd.DataFrame, beta: np.ndarray) -> float:
    if win.empty:
        return np.nan
    Xw = np.column_stack([np.ones(len(win)), win.iloc[:, 1].values])
    ar = win.iloc[:, 0].values - Xw @ beta
    return float(np.nansum(ar))


def build_event_asset_panel(events: pd.DataFrame, asset_symbols: List[str], price_panel: pd.DataFrame, exposure_df: pd.DataFrame, cfg: Config) -> pd.DataFrame:
    ret = price_panel.pivot(index="date", columns="symbol", values="ret").sort_index()
    mcap = price_panel.pivot(index="date", columns="symbol", values="market_cap").sort_index()
    vol = price_panel.pivot(index="date", columns="symbol", values="volume").sort_index()
    px = price_panel.pivot(index="date", columns="symbol", values="price").sort_index()
    rows = []
    data_end = utc(cfg.effective_data_end_date).floor("D")
    for _, ev in events.iterrows():
        t = utc(ev["event_date"]).floor("D")
        k = int(ev.get("car_post_days", cfg.default_event_car_days))
        for sym in asset_symbols:
            if sym not in ret.columns:
                continue
            y = ret[sym]
            others = [c for c in asset_symbols if c != sym and c in ret.columns]
            if not others:
                continue
            mkt = ret[others].mean(axis=1, skipna=True)
            est_start = t - pd.Timedelta(days=cfg.estimation_pre_days)
            est_end = t - pd.Timedelta(days=cfg.estimation_gap_days)
            est = pd.concat([y, mkt], axis=1).loc[(ret.index >= est_start) & (ret.index <= est_end)].dropna()
            if len(est) < 20:
                continue
            X = np.column_stack([np.ones(len(est)), est.iloc[:, 1].values])
            beta = np.linalg.lstsq(X, est.iloc[:, 0].values, rcond=None)[0]

            has_full = add_days(t, k) <= data_end
            car = np.nan
            if has_full:
                w0, w1 = t, t + pd.Timedelta(days=k)
                win = pd.concat([y, mkt], axis=1).loc[(ret.index >= w0) & (ret.index <= w1)].dropna()
                if len(win) >= k + 1:
                    car = _compute_car(win, beta)
            pre_start = t - pd.Timedelta(days=10)
            pre_end = t - pd.Timedelta(days=1)
            pre_mcap = mcap[sym].loc[(mcap.index >= pre_start) & (mcap.index <= pre_end)].dropna() if sym in mcap.columns else pd.Series(dtype=float)
            pre_vol = vol[sym].loc[(vol.index >= pre_start) & (vol.index <= pre_end)].dropna() if sym in vol.columns else pd.Series(dtype=float)
            pre_ret = y.loc[(ret.index >= pre_start) & (ret.index <= pre_end)].dropna()
            rows.append({
                "event_id": ev["event_id"], "event_date": t, "event_type": ev["event_type"], "event_weight": ev.get("event_weight", np.nan), "event_name": ev.get("event_name", ""),
                "placebo_sim": ev.get("placebo_sim", np.nan),
                "symbol": sym, "asset_name": sym.replace("USDT", ""), "car_post_days_used": k, "car_has_full_post_window": has_full,
                "car_event_window": car, "car_event_window_bps": np.nan if pd.isna(car) else car * 10000,
                "pre_log_mcap": np.log(pre_mcap.mean()) if len(pre_mcap) and pre_mcap.mean() > 0 else np.nan,
                "pre_log_volume": np.log(pre_vol.mean()) if len(pre_vol) and pre_vol.mean() > 0 else np.nan,
                "pre_volatility": pre_ret.std(ddof=0) if len(pre_ret) > 1 else np.nan,
                "pre_beta": float(beta[1]) if len(beta) > 1 else np.nan,
                "pre_turnover": float((pre_vol / pre_mcap).mean()) if len(pre_mcap) and len(pre_vol) else np.nan, "use_case_group": ASSET_MASTER[sym]["group"],
            })
    panel = pd.DataFrame(rows)
    if panel.empty:
        return panel
    exp = exposure_df.drop(columns=["event_date"], errors="ignore")
    panel = panel.merge(exp, on=["event_id", "symbol", "use_case_group"], how="left")
    panel["car_event_window_winsor"] = panel.groupby("event_id")["car_event_window"].transform(lambda s: winsorize_series(s, 0.02, 0.98))
    panel["car_event_window_event_z"] = panel.groupby("event_id")["car_event_window"].transform(zscore)
    # WLS weight: more weight to liquid and less noisy assets. Clip to avoid one asset dominating.
    raw_w = np.exp(panel["pre_log_mcap"].fillna(panel["pre_log_mcap"].median())) / (panel["pre_volatility"].fillna(panel["pre_volatility"].median()) ** 2 + 1e-6)
    panel["w_liquidity_precision"] = raw_w / np.nanmedian(raw_w)
    panel["w_liquidity_precision"] = panel["w_liquidity_precision"].clip(lower=0.2, upper=5.0)
    return panel


