def fit_model(formula: str, data: pd.DataFrame, cov_type: str = "HC1", cluster_col: Optional[str] = None, weights_col: Optional[str] = None):
    try:
        d = data.copy()
        if d.empty:
            return None
        if weights_col is not None and weights_col in d.columns:
            model = smf.wls(formula, data=d, weights=d[weights_col].fillna(1.0)).fit()
        else:
            model = smf.ols(formula, data=d).fit()
        if cov_type == "cluster" and cluster_col is not None and cluster_col in d.columns and d[cluster_col].nunique() >= 2:
            return model.get_robustcov_results(cov_type="cluster", groups=d[cluster_col])
        return model.get_robustcov_results(cov_type=cov_type)
    except Exception as e:
        if getattr(CFG, "verbose_download_logs", False):
            print(f"[regression failed] {formula}: {e}")
        return None


def _params_index(model):
    try:
        return list(model.model.exog_names)
    except Exception:
        return list(model.params.index)


def extract_terms(model, reg_df: pd.DataFrame, model_name: str, dep_var: str, terms: List[str]) -> pd.DataFrame:
    names = _params_index(model) if model is not None else []
    rows = []
    for term in terms:
        if model is None or term not in names:
            rows.append({"model_name": model_name, "dep_var": dep_var, "term": term, "coef": np.nan, "std_err": np.nan, "t": np.nan, "p_value": np.nan, "n_obs": len(reg_df) if reg_df is not None else 0, "n_events": reg_df["event_id"].nunique() if reg_df is not None and "event_id" in reg_df else 0, "n_assets": reg_df["symbol"].nunique() if reg_df is not None and "symbol" in reg_df else 0})
        else:
            idx = names.index(term)
            rows.append({
                "model_name": model_name, "dep_var": dep_var, "term": term,
                "coef": float(model.params[idx]), "std_err": float(model.bse[idx]), "t": float(model.tvalues[idx]), "p_value": float(model.pvalues[idx]),
                "n_obs": int(model.nobs), "n_events": reg_df["event_id"].nunique() if "event_id" in reg_df else 0, "n_assets": reg_df["symbol"].nunique() if "symbol" in reg_df else 0,
            })
    return pd.DataFrame(rows)


