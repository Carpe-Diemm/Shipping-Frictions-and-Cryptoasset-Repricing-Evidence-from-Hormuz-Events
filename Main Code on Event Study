def summarize_pre_event_objective_metrics(events: pd.DataFrame, asset_symbols: List[str], price_panel: pd.DataFrame, cm_panel: pd.DataFrame, artemis_panel: pd.DataFrame, cfg: Config) -> pd.DataFrame:
    rows = []
    price = price_panel.copy()
    for _, ev in events.iterrows():
        t = utc(ev["event_date"]).floor("D")
        pre_end = t - pd.Timedelta(days=cfg.objective_gap_days)
        pre_start = pre_end - pd.Timedelta(days=cfg.objective_pre_days - 1)
        for sym in asset_symbols:
            pz = price[(price["symbol"] == sym) & (price["date"] >= pre_start) & (price["date"] <= pre_end)].copy()
            mean_mcap = pz["market_cap"].mean() if not pz.empty else np.nan
            sum_vol = pz["volume"].sum() if not pz.empty else np.nan
            mean_vol = pz["volume"].mean() if not pz.empty else np.nan
            cg_turnover = np.nan if pd.isna(mean_mcap) or mean_mcap <= 0 else sum_vol / mean_mcap

            cz = cm_panel[(cm_panel["symbol"] == sym) & (cm_panel["date"] >= pre_start) & (cm_panel["date"] <= pre_end)].copy() if cm_panel is not None and not cm_panel.empty else pd.DataFrame()
            tx_val_sum = cz["TxTfrValAdjUSD"].sum(min_count=1) if not cz.empty and "TxTfrValAdjUSD" in cz else np.nan
            active_mean = cz["AdrActCnt"].mean() if not cz.empty and "AdrActCnt" in cz else np.nan
            txcnt_sum = cz["TxCnt"].sum(min_count=1) if not cz.empty and "TxCnt" in cz else np.nan
            cm_obs = int(cz[[c for c in CM_METRICS if c in cz.columns]].notna().any(axis=1).sum()) if not cz.empty else 0

            transfer_mcap = np.nan if pd.isna(tx_val_sum) or pd.isna(mean_mcap) or mean_mcap <= 0 else tx_val_sum / mean_mcap
            active_per_billion = np.nan if pd.isna(active_mean) or pd.isna(mean_mcap) or mean_mcap <= 0 else active_mean / (mean_mcap / 1e9)
            txcnt_per_billion = np.nan if pd.isna(txcnt_sum) or pd.isna(mean_mcap) or mean_mcap <= 0 else txcnt_sum / (mean_mcap / 1e9)

            az = artemis_panel[(artemis_panel["symbol"] == sym) & (artemis_panel["date"] >= pre_start) & (artemis_panel["date"] <= pre_end)].copy() if artemis_panel is not None and not artemis_panel.empty else pd.DataFrame()
            art_sum = az["p2p_stablecoin_transfer_volume"].sum(min_count=1) if not az.empty else np.nan
            art_ratio = np.nan if pd.isna(art_sum) or pd.isna(mean_mcap) or mean_mcap <= 0 else art_sum / mean_mcap

            rows.append({
                "event_id": ev["event_id"], "event_date": t, "symbol": sym,
                "objective_window_start": pre_start, "objective_window_end": pre_end,
                "mean_mcap_90d": mean_mcap, "sum_exchange_volume_90d": sum_vol, "mean_exchange_volume_90d": mean_vol,
                "cg_exchange_turnover_mcap_90d": cg_turnover,
                "cm_TxTfrValAdjUSD_sum_90d": tx_val_sum,
                "cm_AdrActCnt_mean_90d": active_mean,
                "cm_TxCnt_sum_90d": txcnt_sum,
                "cm_obs_days_90d": cm_obs,
                "cm_transfer_mcap_ratio_90d": transfer_mcap,
                "cm_activeaddr_per_billion_mcap_90d": active_per_billion,
                "cm_txcnt_per_billion_mcap_90d": txcnt_per_billion,
                "artemis_p2p_stablecoin_transfer_sum_90d": art_sum,
                "artemis_stablecoin_mcap_ratio_90d": art_ratio,
                "use_case_group": ASSET_MASTER[sym]["group"],
            })
    out = pd.DataFrame(rows)
    # Transform skewed ratios. Z-score within each event/episode to focus on cross-sectional exposure.
    log_cols = {
        "cm_transfer_mcap_ratio_90d": "log_cm_transfer_mcap_ratio_90d",
        "cm_activeaddr_per_billion_mcap_90d": "log_cm_activeaddr_per_billion_mcap_90d",
        "cm_txcnt_per_billion_mcap_90d": "log_cm_txcnt_per_billion_mcap_90d",
        "cg_exchange_turnover_mcap_90d": "log_cg_exchange_turnover_mcap_90d",
        "artemis_stablecoin_mcap_ratio_90d": "log_artemis_stablecoin_mcap_ratio_90d",
    }
    for raw, logc in log_cols.items():
        out[logc] = np.log1p(pd.to_numeric(out[raw], errors="coerce").clip(lower=0))
        out[logc + "_z"] = out.groupby("event_id")[logc].transform(zscore)

    onchain_components = [
        "log_cm_transfer_mcap_ratio_90d_z",
        "log_cm_activeaddr_per_billion_mcap_90d_z",
        "log_cm_txcnt_per_billion_mcap_90d_z",
    ]
    broad_components = onchain_components + ["log_cg_exchange_turnover_mcap_90d_z"]
    artemis_col = "log_artemis_stablecoin_mcap_ratio_90d_z"

    out["objective_onchain_composite_z"] = out[onchain_components].mean(axis=1, skipna=True)
    out["objective_broad_composite_z"] = out[broad_components].mean(axis=1, skipna=True)
    # Main variable: Artemis stablecoin exposure if available; otherwise on-chain composite; otherwise broad fallback.
    out["objective_primary_z"] = out[artemis_col]
    out.loc[out["objective_primary_z"].isna(), "objective_primary_z"] = out.loc[out["objective_primary_z"].isna(), "objective_onchain_composite_z"]
    out.loc[out["objective_primary_z"].isna(), "objective_primary_z"] = out.loc[out["objective_primary_z"].isna(), "objective_broad_composite_z"]
    out["objective_source"] = np.where(out[artemis_col].notna(), "artemis_p2p_stablecoin",
                               np.where(out["objective_onchain_composite_z"].notna(), "coinmetrics_onchain", "coingecko_turnover_fallback"))
    return out


