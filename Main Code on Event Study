def utc(dt) -> pd.Timestamp:
    ts = pd.Timestamp(dt)
    if ts.tzinfo is None:
        return ts.tz_localize("UTC")
    return ts.tz_convert("UTC")


def add_days(ts, n: int) -> pd.Timestamp:
    return utc(ts).floor("D") + pd.Timedelta(days=int(n))


def zscore(s: pd.Series) -> pd.Series:
    s = pd.to_numeric(s, errors="coerce")
    sd = s.std(ddof=0)
    if pd.isna(sd) or sd == 0:
        return pd.Series(np.nan, index=s.index)
    return (s - s.mean()) / sd


def winsorize_series(s: pd.Series, lower=0.02, upper=0.98) -> pd.Series:
    s2 = pd.to_numeric(s, errors="coerce")
    lo = s2.quantile(lower)
    hi = s2.quantile(upper)
    return s2.clip(lo, hi)


