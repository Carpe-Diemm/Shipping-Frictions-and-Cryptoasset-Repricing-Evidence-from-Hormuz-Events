def fetch_artemis_p2p_stablecoin_volume(artemis_symbol: str, start_dt: datetime, end_dt: datetime) -> pd.DataFrame:
    """Best-effort optional Artemis call.

    Artemis endpoint conventions may differ by account plan. If ARTEMIS_API_KEY is absent or
    the endpoint returns an error, the script silently falls back to Coin Metrics / CoinGecko variables.
    """
    if not CFG.artemis_api_key or not artemis_symbol:
        return pd.DataFrame(columns=["date", "artemis_symbol", "p2p_stablecoin_transfer_volume"])
    payload = {"symbol": artemis_symbol, "start": str(utc(start_dt).date()), "end": str(utc(end_dt).date()), "base": CFG.artemis_base_url}
    cpath = cache_path("artemis_p2p_stablecoin_volume", payload)
    cached = load_cache(cpath)
    if cached is not None:
        df = pd.DataFrame(cached)
        if not df.empty:
            df["date"] = pd.to_datetime(df["date"], utc=True, errors="coerce")
        return df
    # Common Artemis docs reference /data/P2P_STABLECOIN_TRANSFER_VOLUME.
    url = f"{CFG.artemis_base_url}/data/P2P_STABLECOIN_TRANSFER_VOLUME"
    headers = {"Authorization": f"Bearer {CFG.artemis_api_key}", "x-api-key": CFG.artemis_api_key, "Accept": "application/json"}
    params_variants = [
        {"symbol": artemis_symbol, "startDate": str(utc(start_dt).date()), "endDate": str(utc(end_dt).date())},
        {"symbols": artemis_symbol, "start_date": str(utc(start_dt).date()), "end_date": str(utc(end_dt).date())},
    ]
    for params in params_variants:
        try:
            data = request_json_with_backoff(url, params=params, headers=headers, timeout=CFG.timeout_sec, max_retries=2)
            rows = data.get("data", data if isinstance(data, list) else []) if isinstance(data, (dict, list)) else []
            df = pd.DataFrame(rows)
            if df.empty:
                continue
            # Try to infer date and volume column.
            date_col = next((c for c in df.columns if str(c).lower() in ["date", "time", "timestamp"]), None)
            vol_col = next((c for c in df.columns if "volume" in str(c).lower() or "transfer" in str(c).lower()), None)
            if date_col is None or vol_col is None:
                continue
            out = pd.DataFrame({
                "date": pd.to_datetime(df[date_col], utc=True, errors="coerce").dt.floor("D"),
                "artemis_symbol": artemis_symbol,
                "p2p_stablecoin_transfer_volume": pd.to_numeric(df[vol_col], errors="coerce"),
            }).dropna(subset=["date"])
            save_cache(cpath, out.assign(date=out["date"].astype(str)).to_dict(orient="records"))
            return out
        except Exception:
            continue
    return pd.DataFrame(columns=["date", "artemis_symbol", "p2p_stablecoin_transfer_volume"])


def build_artemis_panel(asset_symbols: List[str], start_dt: datetime, end_dt: datetime) -> pd.DataFrame:
