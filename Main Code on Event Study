    out["success"] = out["status"].astype(str).isin(["downloaded", "cache", "built_from_price_panel"])
    # Show the successful source if present; otherwise show the explicit all_sources_failed row if available.
    rows = []
    for var, d in out.groupby("variable", dropna=False):
