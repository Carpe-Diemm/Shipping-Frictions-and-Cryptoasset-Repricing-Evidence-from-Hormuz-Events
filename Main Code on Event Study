def ensure_cache_dir():
    Path(CFG.cache_dir).mkdir(parents=True, exist_ok=True)


def ensure_output_dir():
    Path(CFG.output_dir).mkdir(parents=True, exist_ok=True)


def cache_path(prefix: str, payload: dict) -> Path:
    ensure_cache_dir()
    raw = json.dumps(payload, sort_keys=True, ensure_ascii=False, default=str)
    h = hashlib.md5(raw.encode("utf-8")).hexdigest()
    return Path(CFG.cache_dir) / f"{prefix}_{h}.json"


def save_cache(path: Path, obj):
    with open(path, "w", encoding="utf-8") as f:
        json.dump(obj, f, ensure_ascii=False)


def load_cache(path: Path):
    if not path.exists():
        return None
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def request_json_with_backoff(url: str, params: Optional[dict] = None, headers: Optional[dict] = None, timeout: Optional[int] = None, retry_waits: Optional[List[int]] = None, max_retries: Optional[int] = None):
    waits = retry_waits or CFG.retry_waits
    if max_retries is None:
        max_retries = len(waits)
    timeout = timeout or CFG.timeout_sec
    last_msg = None
    for attempt in range(max_retries):
        try:
            r = SESSION.get(url, params=params, headers=headers, timeout=timeout)
        except Exception as e:
            wait = waits[min(attempt, len(waits) - 1)]
            last_msg = f"Request error for {url}: {e}"
            if getattr(CFG, "verbose_download_logs", False):
                print(f"[retry] {last_msg}; sleep {wait}s")
            time.sleep(wait)
            continue
        txt = (r.text or "")[:800]
        if r.status_code == 200:
            try:
                return r.json()
            except Exception as e:
                raise RuntimeError(f"Non-JSON response from {r.url}; preview={txt}") from e
        if r.status_code == 429:
            retry_after = r.headers.get("Retry-After")
            wait = int(retry_after) if retry_after and retry_after.isdigit() else waits[min(attempt, len(waits) - 1)]
            last_msg = f"HTTP 429 from {r.url}; preview={txt}"
            if getattr(CFG, "verbose_download_logs", False):
                print(f"[rate-limit] {last_msg}; sleep {wait}s")
            time.sleep(wait)
            continue
        if r.status_code in (500, 502, 503, 504):
            wait = waits[min(attempt, len(waits) - 1)]
            last_msg = f"HTTP {r.status_code} from {r.url}; preview={txt}"
            if getattr(CFG, "verbose_download_logs", False):
                print(f"[server-retry] {last_msg}; sleep {wait}s")
            time.sleep(wait)
            continue
        raise RuntimeError(f"HTTP {r.status_code} from {r.url}; preview={txt}")
    raise RuntimeError(last_msg or f"Request failed after retries: {url}")


