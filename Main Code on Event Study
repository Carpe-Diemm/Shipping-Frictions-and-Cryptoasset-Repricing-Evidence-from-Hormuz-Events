        if len(dd) < 10 or dd["symbol"].nunique() < 5:
            continue
        model = fit_model(formula, dd, cov_type=cov, cluster_col=cluster, weights_col=weights)
        res = extract_terms(model, dd, f"{label}_{name}", dep, terms)
        res.insert(0, "sample", label)
        out.append(res)
    return pd.concat(out, ignore_index=True) if out else pd.DataFrame()


def run_leave_one_asset(panel: pd.DataFrame, label: str, xvar: str = "objective_primary_z") -> pd.DataFrame:
    base = panel.dropna(subset=["car_event_window", xvar]).copy()
    base_model = fit_model(f"car_event_window ~ {xvar} + C(event_id)", base, cov_type="HC1")
    base_res = extract_terms(base_model, base, "baseline", "car_event_window", [xvar])
    base_coef = base_res.loc[0, "coef"] if not base_res.empty else np.nan
    rows = []
    for sym in sorted(base["symbol"].unique()):
        dd = base[base["symbol"] != sym].copy()
        if len(dd) < 10:
            continue
        model = fit_model(f"car_event_window ~ {xvar} + C(event_id)", dd, cov_type="HC1")
        res = extract_terms(model, dd, f"drop_{sym}", "car_event_window", [xvar]).iloc[0].to_dict()
        res["sample"] = label
        res["dropped_asset"] = sym
        res["baseline_coef"] = base_coef
        res["coef_change"] = res["coef"] - base_coef if pd.notna(base_coef) and pd.notna(res["coef"]) else np.nan
        rows.append(res)
    return pd.DataFrame(rows).sort_values("coef_change", key=lambda s: s.abs(), ascending=False) if rows else pd.DataFrame()


def run_interaction_specs(event_panel: pd.DataFrame, portwatch: pd.DataFrame, pegvol: pd.DataFrame) -> pd.DataFrame:
    d = event_panel.copy()
    if portwatch is not None and not portwatch.empty:
        d = d.merge(portwatch[["event_id", "shipping_disruption_index"]], on="event_id", how="left")
        d["shipping_disruption_z"] = zscore(d.drop_duplicates("event_id").set_index("event_id")["shipping_disruption_index"]).reindex(d["event_id"]).values
    if pegvol is not None and not pegvol.empty:
        peg_cols = ["event_id", "stable_abnormal_volume_z", "usdc_usd_volume_abnormal_z", "usdt_usd_volume_abnormal_z"]
        peg_cols = [c for c in peg_cols if c in pegvol.columns]
        d = d.merge(pegvol[peg_cols], on="event_id", how="left")
        for c in ["stable_abnormal_volume_z", "usdc_usd_volume_abnormal_z", "usdt_usd_volume_abnormal_z"]:
            if c in d.columns:
                tmp = d.drop_duplicates("event_id").set_index("event_id")[c]
                d[c + "_event_z"] = zscore(tmp).reindex(d["event_id"]).values
    out = []
    specs = [
        ("INT_objective_x_shipping", "car_event_window ~ objective_primary_z + objective_primary_z:shipping_disruption_z + C(event_id)", ["objective_primary_z", "objective_primary_z:shipping_disruption_z"]),
        ("INT_objective_x_stable_volume", "car_event_window ~ objective_primary_z + objective_primary_z:stable_abnormal_volume_z_event_z + C(event_id)", ["objective_primary_z", "objective_primary_z:stable_abnormal_volume_z_event_z"]),
        ("INT_objective_x_usdc_volume", "car_event_window ~ objective_primary_z + objective_primary_z:usdc_usd_volume_abnormal_z_event_z + C(event_id)", ["objective_primary_z", "objective_primary_z:usdc_usd_volume_abnormal_z_event_z"]),
        ("INT_objective_x_usdt_volume", "car_event_window ~ objective_primary_z + objective_primary_z:usdt_usd_volume_abnormal_z_event_z + C(event_id)", ["objective_primary_z", "objective_primary_z:usdt_usd_volume_abnormal_z_event_z"]),
    ]
    for name, formula, terms in specs:
        needed_terms = ["car_event_window", "objective_primary_z"]
        if "shipping" in name:
            needed_terms.append("shipping_disruption_z")
        if "stable_volume" in name:
            needed_terms.append("stable_abnormal_volume_z_event_z")
        if "usdc_volume" in name:
            needed_terms.append("usdc_usd_volume_abnormal_z_event_z")
        if "usdt_volume" in name:
            needed_terms.append("usdt_usd_volume_abnormal_z_event_z")
        dd = d.dropna(subset=needed_terms).copy()
        if len(dd) < 20 or dd["event_id"].nunique() < 3:
            continue
        model = fit_model(formula, dd, cov_type="HC1")
        out.append(extract_terms(model, dd, name, "car_event_window", terms))
    return pd.concat(out, ignore_index=True) if out else pd.DataFrame()


