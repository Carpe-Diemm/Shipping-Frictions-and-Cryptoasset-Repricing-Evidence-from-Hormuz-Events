def warning_flags(cov_ep: pd.DataFrame, ep_results: pd.DataFrame, ev7_results: pd.DataFrame, rank_excl_ep: pd.DataFrame, rank_excl_ev7: pd.DataFrame, macro_diag: pd.DataFrame, placebo_pooled: pd.DataFrame) -> pd.DataFrame:
    rows = []
    def add(flag, status, note):
        rows.append({"check": flag, "status": status, "paper_interpretation": note})
    cm_cov = 0
    if cov_ep is not None and not cov_ep.empty and "variable" in cov_ep:
        z = cov_ep[cov_ep["variable"].astype(str).str.contains("cm_", na=False)]
        cm_cov = int(z["non_missing_obs"].sum()) if "non_missing_obs" in z else 0
    add("Coin Metrics on-chain flow", "not available" if cm_cov == 0 else "available", "Do not claim Coin Metrics on-chain-flow evidence if unavailable.")
    for label, res in [("main episode WLS", ep_results), ("seven-event WLS", ev7_results)]:
        if res is not None and not res.empty:
            z = res[res["model_name"].astype(str).str.contains("WLS_liquidity_precision", na=False)]
            if not z.empty:
                pval = float(z.iloc[0]["p_value"])
                add(label, "insignificant" if pval >= 0.05 else "significant", "If insignificant, frame results as equal-weighted cross-sectional evidence, not liquidity-weighted portfolio evidence.")
    for label, rtab in [("main no-L2 turnover", rank_excl_ep), ("seven-event no-L2 turnover", rank_excl_ev7)]:
        if rtab is not None and not rtab.empty:
            z = rtab[rtab["model_name"].astype(str).str.contains("NO_L2_turnover", na=False)]
            if not z.empty:
                pval = float(z.iloc[0]["p_value"])
                add(label, "weaker" if pval >= 0.05 else "still significant", "If weaker, state that L2 assets are an important part of the pattern; do not hide it.")
    if macro_diag is not None and not macro_diag.empty:
        mb = macro_brief(macro_diag)
        external = mb[~mb["variable"].astype(str).str.contains("crypto_mkt", na=False)] if not mb.empty else pd.DataFrame()
        ok = int(external["status"].astype(str).isin(["downloaded", "cache"]).sum()) if not external.empty else 0
        add("external macro controls", "partial/failed" if ok == 0 else f"{ok} external variables loaded", "Only report macro controls that successfully downloaded.")
    add("placebo timing", "available" if placebo_pooled is not None and not placebo_pooled.empty else "empty", "Only report placebo if this table is non-empty.")
    return pd.DataFrame(rows)

