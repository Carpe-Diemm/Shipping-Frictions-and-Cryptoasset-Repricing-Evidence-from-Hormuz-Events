def resolve_existing_file(candidates: List[str], label: str) -> Optional[str]:
    for p in candidates:
        if p and Path(p).exists():
            return str(Path(p))
    print(f"[warning] {label} file not found. PortWatch tables will be empty.")
    return None


def load_portwatch_csv(path: str, kind: str) -> pd.DataFrame:
    df = pd.read_csv(path)
    required_cols = ["DateTime", "Container", "Dry Bulk", "General Cargo", "Roll-on/roll-off", "Tanker", "7-day Moving Average", "Prior Year: 7-day Moving Average"]
    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise RuntimeError(f"{kind} CSV missing columns: {missing}")
    df = df.copy()
    df["DateTime"] = pd.to_datetime(df["DateTime"], utc=True, errors="coerce")
    df = df.dropna(subset=["DateTime"]).sort_values("DateTime").reset_index(drop=True)
    vessel_cols = ["Container", "Dry Bulk", "General Cargo", "Roll-on/roll-off", "Tanker"]
    for c in vessel_cols + ["7-day Moving Average", "Prior Year: 7-day Moving Average"]:
        df[c] = pd.to_numeric(df[c], errors="coerce")
    df["Total"] = df[vessel_cols].sum(axis=1, skipna=True)
    df["kind"] = kind
    return df


def _window_change(df: pd.DataFrame, value_col: str, t: pd.Timestamp, window_days: int, baseline_days: int = 30) -> Tuple[float, float, float, int, int]:
    ew0, ew1 = t - pd.Timedelta(days=window_days), t + pd.Timedelta(days=window_days)
    bw0, bw1 = t - pd.Timedelta(days=baseline_days), t - pd.Timedelta(days=window_days + 1)
    event_slice = df.loc[(df["DateTime"] >= ew0) & (df["DateTime"] <= ew1), value_col].dropna()
    base_slice = df.loc[(df["DateTime"] >= bw0) & (df["DateTime"] <= bw1), value_col].dropna()
    event_mean = event_slice.mean() if len(event_slice) else np.nan
    base_mean = base_slice.mean() if len(base_slice) else np.nan
    change = np.nan if pd.isna(event_mean) or pd.isna(base_mean) or base_mean == 0 else event_mean / base_mean - 1.0
    return change, event_mean, base_mean, len(event_slice), len(base_slice)


def compute_portwatch_metrics(events: pd.DataFrame, cfg: Config) -> pd.DataFrame:
    arr_path = resolve_existing_file(cfg.portwatch_arrivals_candidates, "PortWatch arrivals")
    vol_path = resolve_existing_file(cfg.portwatch_volume_candidates, "PortWatch volume")
    if arr_path is None or vol_path is None:
        return pd.DataFrame()
    arrivals = load_portwatch_csv(arr_path, "arrivals")
    volume = load_portwatch_csv(vol_path, "volume")
    rows = []
    for _, ev in events.iterrows():
        t = utc(ev["event_date"]).floor("D")
        w = int(ev.get("portwatch_window_days", 3))
        arr_tanker, _, _, arr_to, arr_bo = _window_change(arrivals, "Tanker", t, w)
        arr_total, _, _, arr_t, arr_b = _window_change(arrivals, "Total", t, w)
        vol_tanker, _, _, vol_to, vol_bo = _window_change(volume, "Tanker", t, w)
        vol_total, _, _, vol_t, vol_b = _window_change(volume, "Total", t, w)
        mean_change = np.nanmean([arr_tanker, arr_total, vol_tanker, vol_total])
        rows.append({
            "event_id": ev["event_id"], "event_date": t, "event_type": ev["event_type"],
            "arrivals_tanker_change": arr_tanker, "arrivals_total_change": arr_total,
            "volume_tanker_change": vol_tanker, "volume_total_change": vol_total,
            "shipping_disruption_index": -mean_change if pd.notna(mean_change) else np.nan,
            "portwatch_complete": all(pd.notna(x) for x in [arr_tanker, arr_total, vol_tanker, vol_total]),
        })
    return pd.DataFrame(rows)


