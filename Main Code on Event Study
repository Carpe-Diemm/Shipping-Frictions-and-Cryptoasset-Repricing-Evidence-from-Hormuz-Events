def add_rank_based_exposures(exposure: pd.DataFrame) -> pd.DataFrame:
    """Add rank and tercile versions of the main exposure variables."""
    out = exposure.copy()
    rank_inputs = {
        "turnover": "log_cg_exchange_turnover_mcap_90d",
        "settlement_capacity": "log_dl_stablecoin_mcap_ratio_90d",
        "hybrid": "objective_tradable_settlement_z",
        "primary": "objective_primary_z",
    }
    for prefix, col in rank_inputs.items():
        if col not in out.columns:
            continue
        out[f"{prefix}_rank_pct"] = out.groupby("event_id")[col].transform(lambda s: s.rank(pct=True))
        out[f"{prefix}_top_tercile"] = (out[f"{prefix}_rank_pct"] >= 2.0 / 3.0).astype(float)
        out.loc[out[f"{prefix}_rank_pct"].isna(), f"{prefix}_top_tercile"] = np.nan
    return out


def run_rank_and_exclusion_robustness(panel: pd.DataFrame, label: str) -> pd.DataFrame:
    """Run rank, tercile, no-L2, and high-turnover-exclusion robustness checks."""
    if panel is None or panel.empty:
        return pd.DataFrame()
    out = []
    specs = [
        ("RANK_turnover_pct", "car_event_window ~ turnover_rank_pct + C(event_id)", ["turnover_rank_pct"], None),
        ("RANK_turnover_top_tercile", "car_event_window ~ turnover_top_tercile + C(event_id)", ["turnover_top_tercile"], None),
        ("RANK_settlement_capacity_pct", "car_event_window ~ settlement_capacity_rank_pct + C(event_id)", ["settlement_capacity_rank_pct"], None),
        ("RANK_hybrid_pct", "car_event_window ~ hybrid_rank_pct + C(event_id)", ["hybrid_rank_pct"], None),
        ("NO_L2_turnover", "car_event_window ~ log_cg_exchange_turnover_mcap_90d_z + C(event_id)", ["log_cg_exchange_turnover_mcap_90d_z"], lambda d: ~d["symbol"].isin(["ARBUSDT", "OPUSDT"])),
        ("NO_L2_settlement", "car_event_window ~ objective_settlement_capacity_z + C(event_id)", ["objective_settlement_capacity_z"], lambda d: ~d["symbol"].isin(["ARBUSDT", "OPUSDT"])),
        ("NO_L2_hybrid", "car_event_window ~ objective_tradable_settlement_z + C(event_id)", ["objective_tradable_settlement_z"], lambda d: ~d["symbol"].isin(["ARBUSDT", "OPUSDT"])),
    ]
    d0 = panel.dropna(subset=["car_event_window"]).copy()
    if "log_cg_exchange_turnover_mcap_90d" in d0.columns:
        d0["turnover_within_event_rank_desc"] = d0.groupby("event_id")["log_cg_exchange_turnover_mcap_90d"].rank(ascending=False, method="first")
        specs.extend([
            ("EX_TOP2_TURNOVER_turnover", "car_event_window ~ log_cg_exchange_turnover_mcap_90d_z + C(event_id)", ["log_cg_exchange_turnover_mcap_90d_z"], lambda d: d["turnover_within_event_rank_desc"] > 2),
            ("EX_TOP2_TURNOVER_hybrid", "car_event_window ~ objective_tradable_settlement_z + C(event_id)", ["objective_tradable_settlement_z"], lambda d: d["turnover_within_event_rank_desc"] > 2),
        ])
    for name, formula, terms, filt in specs:
        dd = d0.copy()
        if filt is not None:
            try:
                dd = dd.loc[filt(dd)].copy()
            except Exception as e:
                if getattr(CFG, "verbose_download_logs", False):
                    print(f"[robustness filter failed] {name}: {e}")
                continue
        needed = list(dict.fromkeys(["car_event_window"] + terms))
        dd = dd.dropna(subset=[c for c in needed if c in dd.columns]).copy()
        if len(dd) < 10 or dd["symbol"].nunique() < 5:
            continue
        model = fit_model(formula, dd, cov_type="HC1")
        res = extract_terms(model, dd, f"{label}_{name}", "car_event_window", terms)
        res.insert(0, "sample", label)
        out.append(res)
    return pd.concat(out, ignore_index=True) if out else pd.DataFrame()


def make_event_window_variants(events: pd.DataFrame, windows: List[int]) -> pd.DataFrame:
    frames = []
    for w in windows:
        z = events.copy()
        z["original_event_id"] = z["event_id"]
        z["event_id"] = z["event_id"].astype(str) + f"_W{int(w)}"
        z["car_post_days"] = int(w)
        z["event_name"] = z["event_name"].astype(str) + f" [CAR 0-{int(w)}]"
        frames.append(z)
    return pd.concat(frames, ignore_index=True) if frames else pd.DataFrame()


def run_alternative_window_robustness(events: pd.DataFrame, loaded_assets: List[str], price_panel: pd.DataFrame, cm_panel: pd.DataFrame, artemis_panel: pd.DataFrame, defillama_panel: pd.DataFrame, cfg: Config, label: str) -> Tuple[pd.DataFrame, pd.DataFrame]:
    alt_events = make_event_window_variants(events, cfg.alternative_car_windows)
    if alt_events.empty:
        return pd.DataFrame(), pd.DataFrame()
    exposure_alt = summarize_pre_event_objective_metrics(alt_events, loaded_assets, price_panel, cm_panel, artemis_panel, cfg)
    exposure_alt = augment_exposure_with_defillama_stable_metrics(exposure_alt, price_panel, defillama_panel, cfg)
    exposure_alt = add_rank_based_exposures(exposure_alt)
    panel_alt = build_event_asset_panel(alt_events, loaded_assets, price_panel, exposure_alt, cfg)
    results_alt = run_objective_specs(panel_alt, label)
    return panel_alt, results_alt




def _placebo_config(cfg: Config) -> Config:
    """Return the config used for placebo timing tests.

    Pseudo-events are evaluated with the same pre-event exposure and
    expected-return windows as the baseline seven-event specification: a 90-day
    exposure window, a 60-day estimation window, and a six-day estimation gap.
    This makes the actual coefficients and the placebo coefficient distribution
    directly comparable in window length.
    """
    return replace(
        cfg,
        objective_pre_days=int(getattr(cfg, "placebo_objective_pre_days", 90)),
        estimation_pre_days=int(getattr(cfg, "placebo_estimation_pre_days", 60)),
        estimation_gap_days=int(getattr(cfg, "placebo_estimation_gap_days", 6)),
        objective_gap_days=1,
    )


def build_random_placebo_event_sets(true_events: pd.DataFrame, price_panel: pd.DataFrame, cfg: Config, n_sims: Optional[int] = None) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """Build placebo event sets over non-event dates.

    The returned placebo table has K pseudo-events per simulation, where K equals
    the number of supplied true events. Candidate pseudo-event dates are required
    to have enough pre-event history for the 90-day exposure window and the
    60-day expected-return estimation window, and enough post-event data for the
    largest CAR window. Diagnostics are returned so an empty placebo table can
    be explained.
    """
    n_sims = int(n_sims or cfg.placebo_draws)
    diag_rows = []
    if true_events is None or true_events.empty or price_panel is None or price_panel.empty:
        return pd.DataFrame(), pd.DataFrame([{"item": "placebo_input", "value": 0, "note": "true_events or price_panel is empty"}])

    pcfg = _placebo_config(cfg)
    dates = sorted(pd.to_datetime(price_panel["date"].dropna().unique(), utc=True))
    dates = [utc(d).floor("D") for d in dates]
    if not dates:
        return pd.DataFrame(), pd.DataFrame([{"item": "price_dates", "value": 0, "note": "no usable price dates"}])

    max_car = int(pd.to_numeric(true_events.get("car_post_days", cfg.default_event_car_days), errors="coerce").fillna(cfg.default_event_car_days).max())
    min_allowed = min(dates) + pd.Timedelta(days=max(pcfg.objective_pre_days + pcfg.objective_gap_days + 2, pcfg.estimation_pre_days + pcfg.estimation_gap_days + 2))
    max_allowed = utc(cfg.effective_data_end_date).floor("D") - pd.Timedelta(days=max_car + 1)
    true_dates = [utc(x).floor("D") for x in true_events["event_date"].tolist()]
    exclusion = int(getattr(cfg, "placebo_exclusion_days", 5))

    candidates = []
    for d in dates:
        d = utc(d).floor("D")
        if d < min_allowed or d > max_allowed:
            continue
        if any(abs((d - td).days) <= exclusion for td in true_dates):
            continue
        candidates.append(d)

    diag_rows.extend([
        {"item": "price_date_min", "value": str(min(dates).date()), "note": "available price panel start"},
        {"item": "price_date_max", "value": str(max(dates).date()), "note": "available price panel end"},
        {"item": "min_allowed_placebo_date", "value": str(min_allowed.date()), "note": f"uses {pcfg.objective_pre_days}d exposure and {pcfg.estimation_pre_days}d estimation windows"},
        {"item": "max_allowed_placebo_date", "value": str(max_allowed.date()), "note": "keeps room for maximum CAR window"},
        {"item": "true_event_exclusion_days", "value": exclusion, "note": "+/- days around true event dates"},
        {"item": "candidate_placebo_dates", "value": len(candidates), "note": "non-event dates eligible for random sampling"},
        {"item": "requested_placebo_draws", "value": n_sims, "note": "number of Monte Carlo placebo simulations"},
    ])

    # This diagnostic is deliberately explicit because placebo must match the
    # event count of the design being benchmarked. For the seven-event robustness
    # design it should be 7, not 9.
    k_events = int(true_events["event_id"].nunique())
    diag_rows.append({"item": "pseudo_events_per_draw", "value": k_events, "note": "number of pseudo-events in each placebo simulation; should match the benchmark design"})

    if not candidates:
        return pd.DataFrame(), pd.DataFrame(diag_rows)

    rng = np.random.default_rng(cfg.placebo_seed)
    replace_dates = len(candidates) < k_events
    template = true_events.sort_values("event_date").reset_index(drop=True)
    rows = []
    successful = 0
    for sim in range(1, n_sims + 1):
        chosen = rng.choice(np.array(candidates, dtype="datetime64[ns]"), size=k_events, replace=replace_dates)
        chosen = sorted(pd.Timestamp(x) for x in chosen)
        successful += 1
        for j, d in enumerate(chosen):
            base = template.iloc[j % len(template)]
            ts = pd.Timestamp(d)
            ts = ts.tz_localize("UTC") if ts.tzinfo is None else ts.tz_convert("UTC")
            rows.append({
                "placebo_sim": sim,
                "event_id": f"PL{sim:04d}_E{j+1:02d}",
                "event_date": ts,
                "event_type": "placebo_date",
                "event_weight": 1.0,
                "event_name": "Random non-event placebo date",
                "car_post_days": int(base.get("car_post_days", cfg.default_event_car_days)),
                "portwatch_window_days": int(base.get("portwatch_window_days", 3)),
                "stable_window_days": int(base.get("stable_window_days", 7)),
                "peg_window_days": int(base.get("peg_window_days", 3)),
            })
    diag_rows.append({"item": "successful_placebo_draws", "value": successful, "note": "simulations for which pseudo-event dates were drawn"})
    return pd.DataFrame(rows), pd.DataFrame(diag_rows)


def _fit_placebo_core(panel: pd.DataFrame, xvar: str, label: str) -> Optional[dict]:
    """Fit one placebo event-FE CAR regression inside one simulation."""
    if panel is None or panel.empty or xvar not in panel.columns:
        return None
    dd = panel.dropna(subset=["car_event_window", xvar]).copy()
    # Use softer thresholds because settlement-capacity tests only cover 20 assets.
    if len(dd) < 20 or dd["symbol"].nunique() < 8 or dd["event_id"].nunique() < 2:
        return None
    try:
        model = fit_model(f"car_event_window ~ {xvar} + C(event_id)", dd, cov_type="HC1")
        if model is None:
            return None
        names = _params_index(model)
        if xvar not in names:
            return None
        idx = names.index(xvar)
        return {
            "placebo_sim": label,
            "term": xvar,
            "coef": float(model.params[idx]),
            "std_err": float(model.bse[idx]),
            "p_value": float(model.pvalues[idx]),
            "n_obs": int(len(dd)),
            "n_events": int(dd["event_id"].nunique()),
            "n_assets": int(dd["symbol"].nunique()),
        }
    except Exception:
        return None


def _actual_coef_for_placebo(panel: pd.DataFrame, xvar: str) -> float:
    if panel is None or panel.empty or xvar not in panel.columns:
        return np.nan
    dd = panel.dropna(subset=["car_event_window", xvar]).copy()
    if len(dd) < 20 or dd["event_id"].nunique() < 2:
        return np.nan
    try:
        model = fit_model(f"car_event_window ~ {xvar} + C(event_id)", dd, cov_type="HC1")
        if model is None:
            return np.nan
        names = _params_index(model)
        if xvar not in names:
            return np.nan
        return float(model.params[names.index(xvar)])
    except Exception:
        return np.nan


def summarize_placebo_empirical(placebo_dist: pd.DataFrame, actual_panel: pd.DataFrame) -> pd.DataFrame:
    """Summarize placebo coefficient distributions against the actual seven-event coefficient."""
    if placebo_dist is None or placebo_dist.empty:
        return pd.DataFrame()
    labels = {
        "log_cg_exchange_turnover_mcap_90d_z": "Exchange turnover intensity",
        "objective_settlement_capacity_z": "DefiLlama stablecoin supply / mcap",
        "objective_tradable_settlement_z": "Mapped-sample turnover + stablecoin supply composite",
        "objective_turnover_x_settlement_z": "Turnover x stablecoin supply",
    }
    rows = []
    for term, d in placebo_dist.dropna(subset=["coef"]).groupby("term"):
        actual = _actual_coef_for_placebo(actual_panel, term)
        coefs = pd.to_numeric(d["coef"], errors="coerce").dropna()
        if coefs.empty or pd.isna(actual):
            continue
        p_right = float(((coefs >= actual).sum() + 1) / (len(coefs) + 1))
        p_two = float(((np.abs(coefs) >= abs(actual)).sum() + 1) / (len(coefs) + 1))
        percentile = float((coefs < actual).mean())
        rows.append({
            "metric": labels.get(term, term),
            "term": term,
            "actual_coef": actual,
            "placebo_mean": float(coefs.mean()),
            "placebo_std": float(coefs.std(ddof=0)),
            "placebo_q05": float(coefs.quantile(0.05)),
            "placebo_q50": float(coefs.quantile(0.50)),
            "placebo_q95": float(coefs.quantile(0.95)),
            "actual_percentile": percentile,
            "empirical_p_right_tail": p_right,
            "empirical_p_two_sided": p_two,
            "n_sims_valid": int(len(coefs)),
            "median_n_obs": float(d["n_obs"].median()) if "n_obs" in d.columns else np.nan,
        })
    return pd.DataFrame(rows)


def _build_actual_placebo_panel(true_events: pd.DataFrame, loaded_assets: List[str], price_panel: pd.DataFrame, cm_panel: pd.DataFrame, artemis_panel: pd.DataFrame, defillama_panel: pd.DataFrame, cfg: Config) -> pd.DataFrame:
    """Build the actual seven-event panel used to benchmark placebo coefficients."""
    actual_exposure = summarize_pre_event_objective_metrics(true_events, loaded_assets, price_panel, cm_panel, artemis_panel, cfg)
    actual_exposure = augment_exposure_with_defillama_stable_metrics(actual_exposure, price_panel, defillama_panel, cfg)
    actual_exposure = add_rank_based_exposures(actual_exposure)
    return build_event_asset_panel(true_events, loaded_assets, price_panel, actual_exposure, cfg)


def _fit_placebo_distribution_from_panel(panel_pl: pd.DataFrame, xvars: List[str]) -> pd.DataFrame:
    """Fit placebo regressions from a pseudo-event asset panel."""
    rows = []
    if panel_pl is not None and not panel_pl.empty and "placebo_sim" in panel_pl.columns:
        for sim, dd in panel_pl.groupby("placebo_sim"):
            for x in xvars:
                r = _fit_placebo_core(dd, x, int(sim))
                if r is not None:
                    rows.append(r)
    return pd.DataFrame(rows)


def run_placebo_timing_tests(true_events: pd.DataFrame, loaded_assets: List[str], price_panel: pd.DataFrame, cm_panel: pd.DataFrame, artemis_panel: pd.DataFrame, defillama_panel: pd.DataFrame, cfg: Config) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    """Run same-window placebo timing tests over randomly selected non-event dates.

    This version is chunked and progress-reporting so the script does not appear
    to hang after the alternative-window table. The placebo pseudo-events use a
    90-day exposure window, a 60-day expected-return estimation window, and a
    six-day estimation gap, matching the baseline seven-event design.
    """
    pcfg = _placebo_config(cfg)
    n_sims = int(getattr(cfg, "placebo_draws", 100))
    chunk_size = max(1, int(getattr(cfg, "placebo_chunk_size", 10)))
    progress_every = max(1, int(getattr(cfg, "placebo_progress_every", 10)))
    xvars = [
        "log_cg_exchange_turnover_mcap_90d_z",
        "objective_settlement_capacity_z",
        "objective_tradable_settlement_z",
        "objective_turnover_x_settlement_z",
    ]

    print(f"[placebo] starting same-window timing placebo: requested_draws={n_sims}, chunk_size={chunk_size}", flush=True)
    placebo_events, diag = build_random_placebo_event_sets(true_events, price_panel, cfg, n_sims=n_sims)
    if placebo_events.empty:
        print("[placebo] no pseudo-event dates could be generated; see diagnostics below.", flush=True)
        return pd.DataFrame(), pd.DataFrame(), pd.DataFrame(), pd.DataFrame(), diag

    actual_panel = _build_actual_placebo_panel(true_events, loaded_assets, price_panel, cm_panel, artemis_panel, defillama_panel, cfg)

    all_dist = []
    all_panel_brief = []
    sims = sorted(pd.to_numeric(placebo_events["placebo_sim"], errors="coerce").dropna().astype(int).unique())
    total = len(sims)
    t0 = time.time()

    for i in range(0, total, chunk_size):
        chunk_sims = sims[i:i + chunk_size]
        pe_chunk = placebo_events[placebo_events["placebo_sim"].isin(chunk_sims)].copy()
        try:
            exposure_pl = summarize_pre_event_objective_metrics(pe_chunk, loaded_assets, price_panel, cm_panel, artemis_panel, pcfg)
            exposure_pl = augment_exposure_with_defillama_stable_metrics(exposure_pl, price_panel, defillama_panel, pcfg)
            exposure_pl = add_rank_based_exposures(exposure_pl)
            panel_pl = build_event_asset_panel(pe_chunk, loaded_assets, price_panel, exposure_pl, pcfg)
            if panel_pl is not None and not panel_pl.empty and "placebo_sim" not in panel_pl.columns:
                panel_pl = panel_pl.merge(pe_chunk[["event_id", "placebo_sim"]].drop_duplicates(), on="event_id", how="left")
            if panel_pl is not None and not panel_pl.empty:
                # Store a lightweight panel summary only for diagnostics.
                cols = [c for c in [
                    "placebo_sim", "event_id", "symbol", "car_event_window",
                    "log_cg_exchange_turnover_mcap_90d_z",
                    "objective_settlement_capacity_z",
                    "objective_tradable_settlement_z",
                    "objective_turnover_x_settlement_z",
                ] if c in panel_pl.columns]
                all_panel_brief.append(panel_pl[cols].copy())
                dist_chunk = _fit_placebo_distribution_from_panel(panel_pl, xvars)
                if not dist_chunk.empty:
                    all_dist.append(dist_chunk)
        except KeyboardInterrupt:
            raise
        except Exception as e:
            if getattr(cfg, "verbose_download_logs", False):
                print(f"[placebo] chunk {i//chunk_size + 1} failed: {e}", flush=True)

        done = min(i + chunk_size, total)
        if done == total or done % progress_every == 0:
            elapsed = time.time() - t0
            valid_so_far = pd.concat(all_dist, ignore_index=True) if all_dist else pd.DataFrame()
            n_valid = int(valid_so_far["placebo_sim"].nunique()) if not valid_so_far.empty else 0
            print(f"[placebo] processed {done}/{total} draws; valid_sims_so_far={n_valid}; elapsed={elapsed:.1f}s", flush=True)

    dist = pd.concat(all_dist, ignore_index=True) if all_dist else pd.DataFrame()
    panel_brief = pd.concat(all_panel_brief, ignore_index=True) if all_panel_brief else pd.DataFrame()
    summary = summarize_placebo_empirical(dist, actual_panel)

    diag_rows = [
        {"item": "placebo_panel_rows", "value": int(len(panel_brief)) if panel_brief is not None and not panel_brief.empty else 0, "note": "pseudo-event asset-event observations processed across chunks"},
        {"item": "placebo_draws_processed", "value": int(total), "note": "pseudo-event draw sets generated and attempted"},
        {"item": "placebo_chunk_size", "value": int(chunk_size), "note": "number of placebo simulations processed per chunk"},
    ]
    for term, label in [
        ("log_cg_exchange_turnover_mcap_90d_z", "valid_turnover_placebo_sims"),
        ("objective_settlement_capacity_z", "valid_settlement_placebo_sims"),
        ("objective_tradable_settlement_z", "valid_hybrid_placebo_sims"),
        ("objective_turnover_x_settlement_z", "valid_interaction_placebo_sims"),
    ]:
        n_valid = int(dist[dist["term"] == term]["placebo_sim"].nunique()) if not dist.empty else 0
        diag_rows.append({"item": label, "value": n_valid, "note": "simulations with valid regression for this term"})
    diag = pd.concat([diag, pd.DataFrame(diag_rows)], ignore_index=True)
    print(f"[placebo] completed; valid regression rows={len(dist)}", flush=True)
    return placebo_events, panel_brief, summary, dist, diag


def _extract_yfinance_close_column(df: pd.DataFrame, ticker: str) -> pd.Series:
    """Return an adjusted-close/close series from a yfinance DataFrame."""
    if df is None or df.empty:
        return pd.Series(dtype=float)
    if isinstance(df.columns, pd.MultiIndex):
        for px in ["Adj Close", "Close"]:
            if px in df.columns.get_level_values(0):
                sub = df[px]
                if isinstance(sub, pd.DataFrame):
                    if ticker in sub.columns:
                        return pd.to_numeric(sub[ticker], errors="coerce")
                    for c in sub.columns:
                        ser = pd.to_numeric(sub[c], errors="coerce")
                        if ser.notna().sum() > 0:
                            return ser
                else:
                    return pd.to_numeric(sub, errors="coerce")
    else:
        for px in ["Adj Close", "Close"]:
            if px in df.columns:
                return pd.to_numeric(df[px], errors="coerce")
    return pd.Series(dtype=float)


def fetch_yfinance_close_series(ticker: str, start_dt: datetime, end_dt: datetime, cfg: Config) -> Tuple[pd.DataFrame, dict]:
    """Download one macro/security price series from Yahoo Finance via yfinance."""
    payload = {"ticker": ticker, "start": str(utc(start_dt).date()), "end": str(utc(end_dt).date())}
    cpath = cache_path("yfinance_macro_close", payload)
    cached = load_cache(cpath)
    diag = {"ticker": ticker, "source": "yfinance", "status": "unknown", "price_obs": 0, "return_obs": 0, "message": ""}
    if cached is not None:
        out = pd.DataFrame(cached)
        if not out.empty:
            out["date"] = pd.to_datetime(out["date"], utc=True, errors="coerce")
            out["close"] = pd.to_numeric(out["close"], errors="coerce")
        diag.update({"status": "cache", "price_obs": int(out["close"].notna().sum()) if "close" in out else 0})
        return out, diag
    try:
        yf = ensure_package("yfinance", "yfinance")
    except Exception as e:
        diag.update({"status": "missing_yfinance", "message": str(e)[:300]})
        return pd.DataFrame(columns=["date", "close"]), diag
    try:
        start_s = str(utc(start_dt).date())
        end_s = str((utc(end_dt).floor("D") + pd.Timedelta(days=1)).date())
        with contextlib.redirect_stdout(io.StringIO()), contextlib.redirect_stderr(io.StringIO()):
            raw = yf.download(ticker, start=start_s, end=end_s, progress=False, auto_adjust=False, actions=False, threads=False)
        if raw is None or raw.empty:
            diag.update({"status": "empty_download", "message": "yfinance returned an empty frame"})
            return pd.DataFrame(columns=["date", "close"]), diag
        close = _extract_yfinance_close_column(raw, ticker)
        if close is None or close.empty:
            diag.update({"status": "no_close_column", "message": f"columns={list(raw.columns)[:10]}"})
            return pd.DataFrame(columns=["date", "close"]), diag
        out = pd.DataFrame({
            "date": pd.to_datetime(close.index, utc=True, errors="coerce").floor("D"),
            "close": pd.to_numeric(close.values, errors="coerce"),
        }).dropna(subset=["date"]).drop_duplicates("date").sort_values("date").reset_index(drop=True)
        out = out.dropna(subset=["close"])
        diag.update({"status": "downloaded", "price_obs": int(out["close"].notna().sum())})
        save_cache(cpath, out.assign(date=out["date"].astype(str)).to_dict(orient="records"))
        return out, diag
    except Exception as e:
        diag.update({"status": "download_error", "message": str(e)[:500]})
        return pd.DataFrame(columns=["date", "close"]), diag


def fetch_fred_close_series(series_id: str, start_dt: datetime, end_dt: datetime, cfg: Config) -> Tuple[pd.DataFrame, dict]:
    """Download a daily macro series from FRED's public CSV endpoint without an API key.

    FRED's graph CSV normally uses columns like ``observation_date,SERIES_ID`` rather
    than ``DATE,SERIES_ID``. This parser accepts both formats and falls back to the
    first numeric value column.
    """
    payload = {"series_id": series_id, "start": str(utc(start_dt).date()), "end": str(utc(end_dt).date()), "parser": "v2"}
    cpath = cache_path("fred_macro_close_v2", payload)
    cached = load_cache(cpath)
    diag = {"ticker": series_id, "source": "fred_public_csv", "status": "unknown", "price_obs": 0, "return_obs": 0, "message": ""}
    if cached is not None:
        out = pd.DataFrame(cached)
        if not out.empty:
            out["date"] = pd.to_datetime(out["date"], utc=True, errors="coerce")
            out["close"] = pd.to_numeric(out["close"], errors="coerce")
        diag.update({"status": "cache", "price_obs": int(out["close"].notna().sum()) if "close" in out else 0})
        return out, diag
    try:
        url = "https://fred.stlouisfed.org/graph/fredgraph.csv"
        params = {"id": series_id}
        headers = {"User-Agent": "Mozilla/5.0 (research script)", "Accept": "text/csv,*/*"}
        r = SESSION.get(url, params=params, headers=headers, timeout=cfg.timeout_sec)
        txt = r.text or ""
        if r.status_code != 200 or not txt.strip():
            diag.update({"status": f"http_{r.status_code}", "message": txt[:160]})
            return pd.DataFrame(columns=["date", "close"]), diag
        df = pd.read_csv(io.StringIO(txt))
        if df.empty:
            diag.update({"status": "empty_download", "message": "FRED returned empty CSV"})
            return pd.DataFrame(columns=["date", "close"]), diag

        lower = {str(c).strip().lower(): c for c in df.columns}
        date_col = lower.get("date") or lower.get("observation_date") or lower.get("time")
        value_col = None
        for c in df.columns:
            if str(c).strip().upper() == str(series_id).upper():
                value_col = c
                break
        if value_col is None:
            for c in df.columns:
                if c == date_col:
                    continue
                tmp = pd.to_numeric(df[c].replace(".", np.nan), errors="coerce")
                if tmp.notna().sum() > 0:
                    value_col = c
                    break
        if date_col is None or value_col is None:
            diag.update({"status": "bad_fred_csv", "message": f"columns={list(df.columns)[:10]}"})
            return pd.DataFrame(columns=["date", "close"]), diag

        out = pd.DataFrame({
            "date": pd.to_datetime(df[date_col], utc=True, errors="coerce").dt.floor("D"),
            "close": pd.to_numeric(df[value_col].replace(".", np.nan), errors="coerce"),
        }).dropna(subset=["date", "close"]).drop_duplicates("date").sort_values("date").reset_index(drop=True)
        out = out[(out["date"] >= utc(start_dt).floor("D")) & (out["date"] <= utc(end_dt).floor("D"))].copy()
        if out.empty:
            diag.update({"status": "empty_download", "message": "FRED returned no usable numeric observations in requested window"})
            return pd.DataFrame(columns=["date", "close"]), diag
        diag.update({"status": "downloaded", "price_obs": int(out["close"].notna().sum()), "message": f"value_col={value_col}"})
        save_cache(cpath, out.assign(date=out["date"].astype(str)).to_dict(orient="records"))
        return out, diag
    except Exception as e:
        diag.update({"status": "download_error", "message": str(e)[:500]})
        return pd.DataFrame(columns=["date", "close"]), diag


