# =========================================================

def build_stablecoin_peg_volume_table(events: pd.DataFrame, stable_panel: pd.DataFrame, cfg: Config) -> pd.DataFrame:
    """Build event-level USDC/USD and USDT/USD peg and volume diagnostics.

    The peg diagnostic uses direct USD prices from CoinGecko and no longer
    relies on a stablecoin cross-pair. This avoids mixing USDC peg behavior
    with movements in the quote stablecoin.

    Reported peg variables:
    - max_usdc_peg_dev = max |USDC/USD - 1| within the event window
    - max_usdt_peg_dev = max |USDT/USD - 1| within the event window
    - max_major_stablecoin_peg_dev = max(max_usdc_peg_dev, max_usdt_peg_dev)

    These are peg-stress diagnostics, not direct measures of stablecoin
    settlement demand.
    """
    empty_cols = [
        "event_id", "event_date",
        "max_usdc_peg_dev", "max_usdt_peg_dev", "max_major_stablecoin_peg_dev",
        "peg_stable_le_10bps", "major_stablecoins_stable_le_10bps",
        "usdc_usd_volume_abnormal_z", "usdt_usd_volume_abnormal_z",
        "stable_abnormal_volume_pct", "stable_abnormal_volume_z",
        "peg_price_source", "peg_volume_interpretation",
    ]
    if stable_panel is None or stable_panel.empty:
        return pd.DataFrame(columns=empty_cols)

    sp = stable_panel.copy()
    sp["date"] = pd.to_datetime(sp["date"], utc=True, errors="coerce").dt.floor("D")
    sp["price"] = pd.to_numeric(sp["price"], errors="coerce")
    sp["volume"] = pd.to_numeric(sp["volume"], errors="coerce")
    sp["market_cap"] = pd.to_numeric(sp["market_cap"], errors="coerce")
    sp = sp.dropna(subset=["date"])

    peg_start = events["event_date"].min() - pd.Timedelta(days=cfg.peg_baseline_days + 10)
    peg_end = cfg.effective_data_end_date + pd.Timedelta(days=1)

    def _build_direct_usd_panel(stable_symbol: str, prefix: str) -> pd.DataFrame:
        z = sp[
            (sp["stable_symbol"] == stable_symbol)
            & (sp["date"] >= utc(peg_start).floor("D"))
            & (sp["date"] <= utc(peg_end).floor("D"))
        ].copy()
        if z.empty:
            return pd.DataFrame(columns=[
                "date", f"{prefix}_usd_price", f"{prefix}_usd_volume",
                f"{prefix}_usd_market_cap", f"{prefix}_peg_dev_abs",
            ])
        z = (
            z.groupby("date", as_index=False)
            .agg(
                **{
                    f"{prefix}_usd_price": ("price", "last"),
                    f"{prefix}_usd_volume": ("volume", "sum"),
                    f"{prefix}_usd_market_cap": ("market_cap", "last"),
                }
            )
            .sort_values("date")
            .reset_index(drop=True)
        )
        z[f"{prefix}_peg_dev_abs"] = (z[f"{prefix}_usd_price"] - 1.0).abs()
        return z

    usdc = _build_direct_usd_panel("USDC", "usdc")
    usdt = _build_direct_usd_panel("USDT", "usdt")

    total_stable = (
        sp.groupby("date", as_index=False)
        .agg(stable_volume=("volume", "sum"), stable_mcap=("market_cap", "sum"))
        .sort_values("date")
        .reset_index(drop=True)
    )

    def _event_stable_stats(panel: pd.DataFrame, prefix: str, t: pd.Timestamp, w: int) -> Tuple[float, float]:
        if panel is None or panel.empty:
            return np.nan, np.nan
        peg_slice = panel[(panel["date"] >= t) & (panel["date"] <= t + pd.Timedelta(days=w))]
        base_slice = panel[
            (panel["date"] >= t - pd.Timedelta(days=cfg.peg_baseline_days))
            & (panel["date"] <= t - pd.Timedelta(days=w + 1))
        ]
        dev_col = f"{prefix}_peg_dev_abs"
        vol_col = f"{prefix}_usd_volume"
        max_dev = peg_slice[dev_col].max() if not peg_slice.empty and dev_col in peg_slice.columns else np.nan
        daily_equiv = peg_slice[vol_col].mean() if not peg_slice.empty and vol_col in peg_slice.columns else np.nan
        base_mean = base_slice[vol_col].mean() if not base_slice.empty and vol_col in base_slice.columns else np.nan
        base_std = base_slice[vol_col].std(ddof=0) if not base_slice.empty and vol_col in base_slice.columns else np.nan
        vol_z = np.nan if pd.isna(base_std) or base_std == 0 else (daily_equiv - base_mean) / base_std
        return max_dev, vol_z

    rows = []
    for _, ev in events.iterrows():
        t = utc(ev["event_date"]).floor("D")
        w = int(ev.get("peg_window_days", 3))

        max_usdc_dev, usdc_usd_vol_z = _event_stable_stats(usdc, "usdc", t, w)
        max_usdt_dev, usdt_usd_vol_z = _event_stable_stats(usdt, "usdt", t, w)

        dev_candidates = [x for x in [max_usdc_dev, max_usdt_dev] if pd.notna(x)]
        max_major_dev = max(dev_candidates) if dev_candidates else np.nan
        both_major_available = pd.notna(max_usdc_dev) and pd.notna(max_usdt_dev)
        major_stable = bool(both_major_available and pd.notna(max_major_dev) and max_major_dev <= 0.001)

        stable_abn_pct, stable_abn_z = np.nan, np.nan
        if not total_stable.empty:
            es = total_stable[
                (total_stable["date"] >= t)
                & (total_stable["date"] <= t + pd.Timedelta(days=w))
            ]["stable_volume"].dropna()
            bs = total_stable[
                (total_stable["date"] >= t - pd.Timedelta(days=cfg.stable_baseline_days))
                & (total_stable["date"] <= t - pd.Timedelta(days=w + 1))
            ]["stable_volume"].dropna()
            if len(es) and len(bs) and bs.mean() != 0:
                stable_abn_pct = es.mean() / bs.mean() - 1.0
                stable_abn_z = (
                    (es.mean() - bs.mean()) / bs.std(ddof=0)
                    if bs.std(ddof=0) != 0
                    else np.nan
                )

        max_major_vol_z = np.nanmax([usdc_usd_vol_z, usdt_usd_vol_z]) if any(pd.notna(x) for x in [usdc_usd_vol_z, usdt_usd_vol_z]) else np.nan
        if major_stable and pd.notna(max_major_vol_z) and max_major_vol_z > 2:
            interp = "major USD stablecoins remain within 10 bps; elevated stablecoin volume"
        elif major_stable:
            interp = "major USD stablecoins remain within 10 bps with no strong volume stress"
        elif pd.notna(max_major_dev):
            interp = "possible major USD stablecoin peg stress"
        else:
            interp = "stablecoin USD peg diagnostic unavailable"

        rows.append({
            "event_id": ev["event_id"],
            "event_date": t,
            "max_usdc_peg_dev": max_usdc_dev,
            "max_usdt_peg_dev": max_usdt_dev,
            "max_major_stablecoin_peg_dev": max_major_dev,
            # Backward-compatible alias: now interpreted as the joint USDC/USD and USDT/USD diagnostic.
            "peg_stable_le_10bps": major_stable,
            "major_stablecoins_stable_le_10bps": major_stable,
            "usdc_usd_volume_abnormal_z": usdc_usd_vol_z,
            "usdt_usd_volume_abnormal_z": usdt_usd_vol_z,
            "stable_abnormal_volume_pct": stable_abn_pct,
            "stable_abnormal_volume_z": stable_abn_z,
            "peg_price_source": "CoinGecko USDC/USD and USDT/USD",
            "peg_volume_interpretation": interp,
        })

    return pd.DataFrame(rows)


