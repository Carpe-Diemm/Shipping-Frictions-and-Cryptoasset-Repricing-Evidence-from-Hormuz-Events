    exposure_ev7 = add_rank_based_exposures(exposure_ev7)
    cov_ep, source_ep = build_objective_coverage_summary(exposure_ep)

    compact_print_df("1A) Source coverage", source_coverage_brief(cov_ep, source_ep, loaded_assets, cm_panel, defillama_panel, artemis_panel), max_rows=20)
    compact_print_df("1B) USDC/USD and USDT/USD peg diagnostics: main episodes", peg_table_brief(pegvol_ep), max_rows=10, digits=6)
    compact_print_df("1C) USDC/USD and USDT/USD peg diagnostics: seven-event design", peg_table_brief(pegvol7), max_rows=10, digits=6)
    if set(loaded_assets) != set(ASSET_UNIVERSE):
        print(f"Missing CoinGecko assets: {sorted(set(ASSET_UNIVERSE) - set(loaded_assets))}")

    ep_panel = build_event_asset_panel(episodes, loaded_assets, price_panel, exposure_ep, CFG)
    ev7_panel = build_event_asset_panel(events7, loaded_assets, price_panel, exposure_ev7, CFG)

    print_section("2) Core regressions")
    ep_results = run_objective_specs(ep_panel, "EPISODE_MAIN")
    ev7_results = run_objective_specs(ev7_panel, "EVENT7_ROBUST")
    compact_print_df("2A) Main two-episode metric comparison", metric_brief(ep_results), max_rows=12)
    compact_print_df("2B) Seven-event robustness metric comparison", metric_brief(ev7_results), max_rows=12)

    print_section("3) Key mechanism and influence diagnostics")
    interactions = run_interaction_specs(ev7_panel, portwatch7, pegvol7)
    compact_print_df("3A) Event-level mechanism interactions, seven-event design", interactions, columns=["model_name", "term", "coef", "std_err", "p_value", "n_obs", "n_events", "n_assets"], max_rows=12)
    loo_ep = run_leave_one_asset(ep_panel, "EPISODE_MAIN", "objective_primary_z")
    loo_ev = run_leave_one_asset(ev7_panel, "EVENT7_ROBUST", "objective_primary_z")
    compact_print_df("3B) Most influential leave-one-asset checks: main episodes", loo_ep.head(8) if not loo_ep.empty else loo_ep, columns=["dropped_asset", "coef", "p_value", "baseline_coef", "coef_change", "n_obs"], max_rows=8)
    compact_print_df("3C) Most influential leave-one-asset checks: seven events", loo_ev.head(8) if not loo_ev.empty else loo_ev, columns=["dropped_asset", "coef", "p_value", "baseline_coef", "coef_change", "n_obs"], max_rows=8)

    print_section("4) Critical robustness checks")
    flags = pd.concat([compact_conclusion_flags(ep_results, "EPISODE_MAIN"), compact_conclusion_flags(ev7_results, "EVENT7_ROBUST")], ignore_index=True)
    compact_print_df("4A) Compact conclusion flags", flags, max_rows=12)

    rank_excl_ep = run_rank_and_exclusion_robustness(ep_panel, "EPISODE_MAIN")
    rank_excl_ev7 = run_rank_and_exclusion_robustness(ev7_panel, "EVENT7_ROBUST")
    compact_print_df("4B) Main episodes: rank/no-L2/top-turnover checks", key_robustness_brief(rank_excl_ep), max_rows=12)
    compact_print_df("4C) Seven events: rank/no-L2/top-turnover checks", key_robustness_brief(rank_excl_ev7), max_rows=12)

    _, alt_results_ep = run_alternative_window_robustness(episodes, loaded_assets, price_panel, cm_panel, artemis_panel, defillama_panel, CFG, "ALT_WINDOW_EPISODE")
    _, alt_results_ev7 = run_alternative_window_robustness(events7, loaded_assets, price_panel, cm_panel, artemis_panel, defillama_panel, CFG, "ALT_WINDOW_EVENT7")
    compact_print_df("4D) Alternative CAR-window robustness: main episodes", alt_window_brief(alt_results_ep), max_rows=8)
    compact_print_df("4E) Alternative CAR-window robustness: seven events", alt_window_brief(alt_results_ev7), max_rows=8)

    # Placebo timing should benchmark the seven-event robustness design, not the
    # concatenated table of seven events plus two episode-level aggregates. Using
    # all_events here would create 9 pseudo-events per simulation and make the
    # placebo n_events diagnostic inconsistent with the seven-event design.
    placebo_events, placebo_panel, placebo_pooled, placebo_distribution, placebo_diag = run_placebo_timing_tests(events7, loaded_assets, price_panel, cm_panel, artemis_panel, defillama_panel, CFG)
    compact_print_df("4F) Placebo timing tests", placebo_brief(placebo_pooled), max_rows=10)
    compact_print_df("4G) Placebo diagnostics", placebo_diag, max_rows=12)
    if placebo_distribution is not None and not placebo_distribution.empty:
        psummary = placebo_distribution.describe(include="all").transpose().reset_index().rename(columns={"index": "variable"})
        compact_print_df("4H) Placebo coefficient distribution summary", psummary, max_rows=20)

    print_section("5) Automatically downloaded macro controls")
    macro_panel, macro_download_diagnostics = download_macro_controls(CFG, data_start, data_end, price_panel=price_panel)
    compact_print_df("5A) Macro download diagnostics", macro_brief(macro_download_diagnostics), max_rows=12)
    macro_events7 = build_event_macro_controls(events7, macro_panel)
    compact_print_df("5B) Event-level macro-control availability", macro_events7, max_rows=10)
    macro_interactions = run_macro_interaction_specs(ev7_panel, macro_events7, "EVENT7_ROBUST")
    compact_print_df("5C) Macro interaction robustness", macro_interactions, columns=["model_name", "term", "coef", "std_err", "p_value", "n_obs", "n_events", "n_assets"], max_rows=20)

    print_section("6) Paper-writing warning flags")
    compact_print_df("6A) What to state carefully in the paper", warning_flags(cov_ep, ep_results, ev7_results, rank_excl_ep, rank_excl_ev7, macro_download_diagnostics, placebo_pooled), max_rows=20)

    print_section("完成")
    print("No CSV files were written. All requested daily event-window outputs were printed to the terminal only.")
    print("Interpretation guide:")
    print("1) TURNOVER = CoinGecko exchange volume / market cap; tradability/attention, not payment flow.")
    print("2) SETTLE_capacity = DefiLlama chain stablecoin supply / native token market cap; capacity proxy, not transfer flow.")
    print("3) HYBRID = mapped-sample composite only: assets without settlement-capacity data are excluded from hybrid regressions.")
    print("4) Significant OLS but insignificant WLS means equal-weighted cross-sectional evidence, not liquidity-weighted portfolio evidence.")
    print("5) If no-L2 turnover weakens, write this as a limitation: L2 assets are economically important contributors.")
    print("6) Only report external macro controls that successfully downloaded in the macro diagnostics table.")

