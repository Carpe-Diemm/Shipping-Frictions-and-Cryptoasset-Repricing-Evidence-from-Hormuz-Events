def build_objective_snapshot(exposure: pd.DataFrame, event_id: str, top_n: int = 8) -> pd.DataFrame:
    d = exposure[exposure["event_id"] == event_id].copy()
    cols = ["symbol", "use_case_group", "objective_primary_z", "objective_source", "cm_transfer_mcap_ratio_90d", "cg_exchange_turnover_mcap_90d"]
    hi = d.sort_values("objective_primary_z", ascending=False).head(top_n).copy()
    lo = d.sort_values("objective_primary_z", ascending=True).head(top_n).copy()
    hi.insert(0, "bucket", "highest_objective_exposure")
    lo.insert(0, "bucket", "lowest_objective_exposure")
    return pd.concat([hi, lo], ignore_index=True)[["bucket"] + cols]



def build_key_metric_comparison(results: pd.DataFrame) -> pd.DataFrame:
    """Compact comparison of turnover, settlement-capacity, and hybrid variables."""
    if results is None or results.empty:
        return pd.DataFrame()
    keep = [
        ("TURNOVER_raw_FE_HC1", "log_cg_exchange_turnover_mcap_90d_z", "Exchange turnover intensity"),
        ("TURNOVER_symbol_cluster", "log_cg_exchange_turnover_mcap_90d_z", "Exchange turnover, symbol-clustered"),
        ("TURNOVER_controls_FE_HC1", "log_cg_exchange_turnover_mcap_90d_z", "Exchange turnover + controls"),
        ("SETTLE_capacity_FE_HC1", "objective_settlement_capacity_z", "DefiLlama stablecoin supply / mcap"),
        ("SETTLE_capacity_symbol_cluster", "objective_settlement_capacity_z", "Stablecoin supply / mcap, clustered"),
        ("SETTLE_capacity_controls_FE_HC1", "objective_settlement_capacity_z", "Stablecoin supply / mcap + controls"),
        ("SETTLE_growth_FE_HC1", "objective_settlement_growth_z", "Stablecoin supply growth"),
        ("HYBRID_tradable_settlement_FE_HC1", "objective_tradable_settlement_z", "Mapped-sample turnover + stablecoin supply composite"),
        ("HYBRID_turnover_x_settlement_FE_HC1", "objective_turnover_x_settlement_z", "Turnover x stablecoin supply"),
    ]
    rows = []
    for suffix, term, label in keep:
        z = results[results["model_name"].str.endswith(suffix) & (results["term"] == term)].copy()
        if z.empty:
            continue
        r = z.iloc[0]
        rows.append({
            "sample": r.get("sample", ""),
            "metric": label,
            "term": term,
            "coef": r["coef"],
            "std_err": r["std_err"],
            "p_value": r["p_value"],
            "n_obs": r["n_obs"],
            "n_events": r["n_events"],
            "n_assets": r["n_assets"],
            "support": "significant +" if pd.notna(r["coef"]) and r["coef"] > 0 and r["p_value"] < 0.05 else ("positive, ns" if pd.notna(r["coef"]) and r["coef"] > 0 else "not supportive"),
        })
    return pd.DataFrame(rows)


