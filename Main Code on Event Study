def detect_coingecko_mode(api_key: str) -> Tuple[str, Dict[str, str]]:
    if not api_key:
        raise RuntimeError("CoinGecko API key is empty.")
    # Try Pro first, then Demo.
    try:
        r = SESSION.get("https://pro-api.coingecko.com/api/v3/ping", headers={"x-cg-pro-api-key": api_key}, timeout=30)
        if r.status_code == 200:
            return "https://pro-api.coingecko.com/api/v3", {"x-cg-pro-api-key": api_key}
    except Exception:
        pass
    try:
        r = SESSION.get("https://api.coingecko.com/api/v3/ping", headers={"x-cg-demo-api-key": api_key}, timeout=30)
        if r.status_code == 200:
            return "https://api.coingecko.com/api/v3", {"x-cg-demo-api-key": api_key}
    except Exception:
        pass
    raise RuntimeError("Could not validate CoinGecko API key as Pro or Demo.")


def fetch_coingecko_market_range(coin_id: str, from_ts: int, to_ts: int, base_url: str, headers: Dict[str, str]) -> pd.DataFrame:
    # Demo API has practical historical limits for some endpoints. Clamp to a one-year window relative to end.
    if "api.coingecko.com/api/v3" in base_url:
        max_lookback_sec = 365 * 24 * 3600
        min_allowed_ts = to_ts - max_lookback_sec + 24 * 3600
        from_ts = max(from_ts, min_allowed_ts)
    payload = {"coin_id": coin_id, "from_ts": from_ts, "to_ts": to_ts, "base_url": base_url}
    cpath = cache_path("coingecko_market", payload)
    cached = load_cache(cpath)
    if cached is not None:
        df = pd.DataFrame(cached)
        if not df.empty:
            df["date"] = pd.to_datetime(df["date"], utc=True, errors="coerce")
        return df
    url = f"{base_url}/coins/{coin_id}/market_chart/range"
    params = {"vs_currency": "usd", "from": from_ts, "to": to_ts}
    data = request_json_with_backoff(url, params=params, headers=headers)
    prices = data.get("prices", [])
    market_caps = data.get("market_caps", [])
    volumes = data.get("total_volumes", [])

    def to_df(arr, name):
        if not arr:
            return pd.DataFrame(columns=["date", name])
        out = pd.DataFrame(arr, columns=["ts_ms", name])
        out["date"] = pd.to_datetime(out["ts_ms"], unit="ms", utc=True).dt.floor("D")
        return out.groupby("date", as_index=False)[name].last()

    out = to_df(prices, "price").merge(to_df(market_caps, "market_cap"), on="date", how="outer").merge(to_df(volumes, "volume"), on="date", how="outer")
    out = out.sort_values("date").reset_index(drop=True)
    save_cache(cpath, out.assign(date=out["date"].astype(str)).to_dict(orient="records"))
    return out


def build_crypto_price_panel(asset_symbols: List[str], cfg: Config, start_dt: datetime, end_dt: datetime) -> pd.DataFrame:
