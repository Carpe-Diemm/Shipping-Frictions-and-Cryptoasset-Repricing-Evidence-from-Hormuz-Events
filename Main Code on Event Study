def build_btc_return_from_price_panel(price_panel: Optional[pd.DataFrame]) -> Tuple[pd.DataFrame, dict]:
    """Build BTC return directly from the already downloaded CoinGecko BTCUSDT series."""
    diag = {"ticker": "BTCUSDT/CoinGecko", "source": "coingecko_asset_panel", "status": "unavailable", "price_obs": 0, "return_obs": 0, "message": "BTCUSDT not found in price panel"}
    if price_panel is None or price_panel.empty:
        return pd.DataFrame(columns=["date", "btc_ret"]), diag
    d = price_panel[price_panel["symbol"].astype(str) == "BTCUSDT"].copy()
    if d.empty:
        return pd.DataFrame(columns=["date", "btc_ret"]), diag
    d["date"] = pd.to_datetime(d["date"], utc=True, errors="coerce").dt.floor("D")
    d["price"] = pd.to_numeric(d["price"], errors="coerce")
    d = d.dropna(subset=["date", "price"]).drop_duplicates("date").sort_values("date")
    d["btc_ret"] = np.log(d["price"].replace(0, np.nan)).diff()
    out = d[["date", "btc_ret"]].copy()
    diag.update({"status": "built_from_price_panel", "price_obs": int(d["price"].notna().sum()), "return_obs": int(out["btc_ret"].notna().sum()), "message": "BTC return built from CoinGecko BTCUSDT price panel"})
    return out, diag


def load_local_macro_controls_if_requested(cfg: Config) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """Optional manual fallback. Disabled by default because the preferred path is auto-download."""
    if not getattr(cfg, "use_local_macro_csv_fallback", False):
        return pd.DataFrame(), pd.DataFrame([{"source": "local_csv", "status": "disabled", "message": "local CSV fallback disabled"}])
    path = resolve_existing_file(cfg.macro_controls_candidates, "optional macro controls")
    if path is None:
        return pd.DataFrame(), pd.DataFrame([{"source": "local_csv", "status": "not_found", "message": "no local macro_controls.csv found"}])
    df = pd.read_csv(path)
    date_col = next((c for c in df.columns if str(c).lower() in ["date", "datetime", "time"]), None)
    if date_col is None:
        return pd.DataFrame(), pd.DataFrame([{"source": "local_csv", "status": "no_date_column", "message": path}])
    df = df.copy()
    df["date"] = pd.to_datetime(df[date_col], utc=True, errors="coerce").dt.floor("D")
    keep = ["date"] + [c for c in ["brent_ret", "vix_ret", "dxy_ret", "sp500_ret", "btc_ret", "crypto_mkt_ret"] if c in df.columns]
    out = df[keep].dropna(subset=["date"]).copy()
    for c in keep:
        if c != "date":
            out[c] = pd.to_numeric(out[c], errors="coerce")
    diag = pd.DataFrame([{"source": "local_csv", "status": "loaded", "message": path, "rows": int(len(out))}])
    return out, diag


def _append_macro_return(frames: List[pd.DataFrame], diagnostics: List[dict], name: str, px: pd.DataFrame, diag: dict):
    diag = dict(diag)
    diag["variable"] = f"{name}_ret"
    if px is None or px.empty or "close" not in px.columns or px["close"].notna().sum() < 3:
        diag["return_obs"] = 0
        diagnostics.append(diag)
        return
    z = px.sort_values("date").copy()
    z[f"{name}_ret"] = np.log(pd.to_numeric(z["close"], errors="coerce").replace(0, np.nan)).diff()
    ret = z[["date", f"{name}_ret"]].dropna(subset=["date"]).copy()
    diag["return_obs"] = int(ret[f"{name}_ret"].notna().sum())
    diagnostics.append(diag)
    frames.append(ret)



def download_macro_controls(cfg: Config, start_dt: datetime, end_dt: datetime, price_panel: Optional[pd.DataFrame] = None) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """Download Brent, VIX, DXY, S&P 500, BTC and crypto-market controls.

    Reliable-source order:
    - BTC: CoinGecko BTCUSDT already in the price panel; fallback Yahoo.
    - Brent: FRED DCOILBRENTEU -> DataHub/EIA Brent CSV -> Stooq/Yahoo.
    - VIX: Cboe official CSV -> FRED VIXCLS -> Stooq/Yahoo.
    - DXY: FRED DTWEXBGS broad dollar index proxy -> Stooq/Yahoo DXY/future tickers.
    - S&P 500: FRED SP500 -> Stooq ^SPX -> Yahoo ^GSPC/SPY.

    All series are converted to log returns and then aggregated over each event window.
    """
    diagnostics = []
    if not getattr(cfg, "macro_download_enabled", True):
        local, local_diag = load_local_macro_controls_if_requested(cfg)
        return local, local_diag
    frames = []

    btc_df, btc_diag = build_btc_return_from_price_panel(price_panel)
    btc_diag = dict(btc_diag); btc_diag["variable"] = "btc_ret"
    if btc_df is not None and not btc_df.empty and btc_df["btc_ret"].notna().sum() >= 3:
        diagnostics.append(btc_diag)
        frames.append(btc_df)
    else:
        diagnostics.append(btc_diag)
        for ticker in getattr(cfg, "macro_yfinance_fallback_tickers", {}).get("btc", ["BTC-USD"]):
            px, diag = fetch_yfinance_close_series(ticker, start_dt, end_dt, cfg)
            diag = dict(diag); diag["variable"] = "btc_ret"; diag["source_priority"] = "btc_yfinance_fallback"
            if px is not None and not px.empty and px["close"].notna().sum() >= 3:
                _append_macro_return(frames, diagnostics, "btc", px, diag)
                break
            diag["return_obs"] = 0; diagnostics.append(diag)

    def candidates_for(name: str):
        cand = []
        if name == "brent":
            fred_id = getattr(cfg, "macro_fred_series", {}).get("brent")
            if fred_id:
                cand.append(("1_fred_brent_spot", lambda: fetch_fred_close_series(fred_id, start_dt, end_dt, cfg)))
            cand.append(("2_datahub_eia_brent", lambda: fetch_datahub_brent_series(start_dt, end_dt, cfg)))
        elif name == "vix":
            cand.append(("1_cboe_official_vix", lambda: fetch_cboe_vix_series(start_dt, end_dt, cfg)))
            fred_id = getattr(cfg, "macro_fred_series", {}).get("vix")
            if fred_id:
                cand.append(("2_fred_vix", lambda: fetch_fred_close_series(fred_id, start_dt, end_dt, cfg)))
        elif name == "dxy":
            fred_id = getattr(cfg, "macro_fred_series", {}).get("dxy")
            if fred_id:
                cand.append(("1_fred_broad_dollar_proxy", lambda: fetch_fred_close_series(fred_id, start_dt, end_dt, cfg)))
        elif name == "sp500":
            fred_id = getattr(cfg, "macro_fred_series", {}).get("sp500")
            if fred_id:
                cand.append(("1_fred_sp500", lambda: fetch_fred_close_series(fred_id, start_dt, end_dt, cfg)))

        for ticker in getattr(cfg, "macro_stooq_tickers", {}).get(name, []):
            cand.append(("3_stooq", lambda ticker=ticker: fetch_stooq_close_series(ticker, start_dt, end_dt, cfg)))

        primary_ticker = getattr(cfg, "macro_yfinance_tickers", {}).get(name, "")
        y_candidates = list(dict.fromkeys([primary_ticker] + list(getattr(cfg, "macro_yfinance_fallback_tickers", {}).get(name, []))))
        for ticker in [x for x in y_candidates if x]:
            cand.append(("4_yfinance", lambda ticker=ticker: fetch_yfinance_close_series(ticker, start_dt, end_dt, cfg)))
        return cand

    for name in ["brent", "vix", "dxy", "sp500"]:
        loaded = False
        attempts = []
        for priority, getter in candidates_for(name):
            try:
                px, diag = getter()
            except Exception as e:
                px = pd.DataFrame(columns=["date", "close"])
                diag = {"source": priority, "ticker": "unknown", "status": "exception", "price_obs": 0, "return_obs": 0, "message": str(e)[:500]}
            diag = dict(diag)
            diag["variable"] = f"{name}_ret"
            diag["source_priority"] = priority
            if name == "dxy" and "fred" in str(diag.get("source", "")):
                diag["message"] = (diag.get("message", "") + " Uses FRED DTWEXBGS as a broad dollar-index proxy, not ICE DXY.").strip()
            if px is not None and not px.empty and "close" in px.columns and px["close"].notna().sum() >= 3:
                diagnostics.extend(attempts)
                _append_macro_return(frames, diagnostics, name, px, diag)
                loaded = True
                break
            diag["return_obs"] = 0
            attempts.append(diag)
        if not loaded:
            diagnostics.extend(attempts)
            diagnostics.append({
                "source": "all_sources",
                "variable": f"{name}_ret",
                "ticker": "FRED/Cboe/DataHub/Stooq/Yahoo",
                "status": "all_sources_failed",
                "price_obs": 0,
                "return_obs": 0,
                "message": "No usable series from configured public sources.",
            })

    if frames:
        out = frames[0]
        for f in frames[1:]:
            out = out.merge(f, on="date", how="outer")
        out = out.sort_values("date").reset_index(drop=True)
    else:
        out = pd.DataFrame(columns=["date"])

    if price_panel is not None and not price_panel.empty and "ret" in price_panel.columns:
        mkt = price_panel.copy()
        mkt["date"] = pd.to_datetime(mkt["date"], utc=True, errors="coerce").dt.floor("D")
        mkt["ret"] = pd.to_numeric(mkt["ret"], errors="coerce")
        crypto = mkt.groupby("date", as_index=False)["ret"].mean().rename(columns={"ret": "crypto_mkt_ret"})
        if out.empty or list(out.columns) == ["date"]:
            out = crypto
        else:
            out = out.merge(crypto, on="date", how="outer")
        diagnostics.append({"source": "coingecko_asset_panel", "variable": "crypto_mkt_ret", "ticker": "equal_weight_30_assets", "status": "built_from_price_panel", "price_obs": np.nan, "return_obs": int(crypto["crypto_mkt_ret"].notna().sum()), "message": "equal-weight mean of available asset log returns"})

    out = out.sort_values("date").reset_index(drop=True) if not out.empty else out
    if (out.empty or len([c for c in out.columns if c != "date"]) == 0) and getattr(cfg, "use_local_macro_csv_fallback", False):
        local, local_diag = load_local_macro_controls_if_requested(cfg)
        diagnostics.extend(local_diag.to_dict(orient="records") if isinstance(local_diag, pd.DataFrame) else [])
        return local, pd.DataFrame(diagnostics)
    return out, pd.DataFrame(diagnostics)


def build_event_macro_controls(events: pd.DataFrame, macro_panel: pd.DataFrame) -> pd.DataFrame:
    if events is None or events.empty or macro_panel is None or macro_panel.empty:
        return pd.DataFrame()
    macro_cols = [c for c in macro_panel.columns if c != "date"]
    rows = []
    for _, ev in events.iterrows():
        t = utc(ev["event_date"]).floor("D")
        k = int(ev.get("car_post_days", 5))
        sl = macro_panel[(macro_panel["date"] >= t) & (macro_panel["date"] <= t + pd.Timedelta(days=k))].copy()
        row = {"event_id": ev["event_id"], "event_date": t, "macro_window_days": k, "macro_obs_days": int(len(sl))}
        for c in macro_cols:
            row[f"{c}_event_sum"] = sl[c].sum(min_count=1) if not sl.empty else np.nan
            row[f"{c}_event_mean"] = sl[c].mean() if not sl.empty else np.nan
        rows.append(row)
    out = pd.DataFrame(rows)
    for c in [x for x in out.columns if x.endswith("_event_sum")]:
        out[c + "_z"] = zscore(out[c])
    return out


def run_macro_interaction_specs(panel: pd.DataFrame, macro_events: pd.DataFrame, label: str) -> pd.DataFrame:
    if panel is None or panel.empty or macro_events is None or macro_events.empty:
        return pd.DataFrame()
    d = panel.merge(macro_events.drop(columns=["event_date"], errors="ignore"), on="event_id", how="left")
    out = []
    macro_z_cols = [c for c in d.columns if c.endswith("_event_sum_z")]
    for m in macro_z_cols:
        dd = d.dropna(subset=["car_event_window", "objective_primary_z", m]).copy()
        if len(dd) < 30 or dd["event_id"].nunique() < 3:
            continue
        term = f"objective_primary_z:{m}"
        formula = f"car_event_window ~ objective_primary_z + objective_primary_z:{m} + C(event_id)"
        model = fit_model(formula, dd, cov_type="HC1")
        res = extract_terms(model, dd, f"{label}_MACRO_INTERACTION_{m}", "car_event_window", ["objective_primary_z", term])
        res.insert(0, "sample", label)
        out.append(res)
    return pd.concat(out, ignore_index=True) if out else pd.DataFrame()

def build_event_count_diagnostic(episodes: pd.DataFrame, events: pd.DataFrame) -> pd.DataFrame:
    rows = [
