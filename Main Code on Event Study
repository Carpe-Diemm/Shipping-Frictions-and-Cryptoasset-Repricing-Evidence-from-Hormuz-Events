def compact_conclusion_flags(main_results: pd.DataFrame, label: str) -> pd.DataFrame:
    rows = []
    for model_name in [f"{label}_MAIN_raw_FE_HC1", f"{label}_MAIN_WLS_liquidity_precision", f"{label}_MAIN_controls_FE_HC1"]:
        z = main_results[(main_results["model_name"] == model_name)] if not main_results.empty else pd.DataFrame()
        if z.empty:
            continue
        r = z.iloc[0]
        interp = "not supportive"
        if pd.notna(r["coef"]) and r["coef"] > 0 and r["p_value"] < 0.05:
            interp = "positive and statistically significant"
        elif pd.notna(r["coef"]) and r["coef"] > 0 and r["p_value"] < 0.10:
            interp = "positive and marginally significant"
        elif pd.notna(r["coef"]) and r["coef"] > 0:
            interp = "positive but insignificant"
        rows.append({"sample": label, "model_name": model_name, "coef": r["coef"], "p_value": r["p_value"], "interpretation": interp})
    return pd.DataFrame(rows)


