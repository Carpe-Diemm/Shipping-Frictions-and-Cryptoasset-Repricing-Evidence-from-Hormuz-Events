# DefiLlama stablecoin-settlement capacity proxy
# =========================================================

def _extract_defillama_usd_value(row: dict) -> float:
    """Robustly extract USD-pegged stablecoin supply from DefiLlama stablecoin chart rows."""
    if not isinstance(row, dict):
        return np.nan
    candidate_keys = [
        "totalCirculatingUSD", "totalCirculating", "totalCirculatingPeggedUSD",
        "totalStablecoins", "stablecoins", "mcap", "marketCap", "totalMcap",
    ]
    for k in candidate_keys:
        if k not in row:
            continue
        v = row.get(k)
        if isinstance(v, dict):
            for kk in ["peggedUSD", "usd", "USD", "total", "value"]:
                if kk in v:
                    try:
                        return float(v[kk])
                    except Exception:
                        pass
        else:
            try:
                return float(v)
            except Exception:
                pass
    return np.nan


def fetch_defillama_stablecoin_chart(chain: str, cfg: Config) -> pd.DataFrame:
    """Fetch daily chain-level stablecoin market cap/supply from DefiLlama.

    This is a free settlement-capacity proxy, not a direct transfer-volume measure.
    """
    if not chain:
        return pd.DataFrame(columns=["date", "defillama_chain", "stablecoin_mcap_usd"])
    payload = {"chain": chain, "base": cfg.defillama_stable_base_url}
    cpath = cache_path("defillama_stablecoin_chain_chart", payload)
    cached = load_cache(cpath)
    if cached is not None:
        df = pd.DataFrame(cached)
        if not df.empty:
            df["date"] = pd.to_datetime(df["date"], utc=True, errors="coerce")
        return df

    from urllib.parse import quote
    chain_variants = list(dict.fromkeys([chain, chain.lower(), chain.replace(" ", "-"), chain.replace(" ", "%20")]))
    urls = []
    for ch in chain_variants:
        q = quote(ch, safe="%")
        urls.extend([
            f"{cfg.defillama_stable_base_url}/stablecoincharts/{q}",
            f"{cfg.defillama_stable_base_url}/stablecoincharts/{q}?stablecoin=1",
        ])
    rows = []
    last_error = None
    for url in urls:
        try:
            data = request_json_with_backoff(url, params=None, headers=None, timeout=cfg.timeout_sec, max_retries=2)
            if isinstance(data, dict):
                raw_rows = data.get("data") or data.get("chart") or data.get("peggedAssets") or []
            elif isinstance(data, list):
                raw_rows = data
            else:
                raw_rows = []
            if not raw_rows:
                continue
            for r in raw_rows:
                if not isinstance(r, dict):
                    continue
                dt = r.get("date") or r.get("timestamp") or r.get("time")
                if dt is None:
                    continue
                try:
                    if isinstance(dt, (int, float)) or (isinstance(dt, str) and dt.isdigit()):
                        date = pd.to_datetime(int(float(dt)), unit="s", utc=True).floor("D")
                    else:
                        date = pd.to_datetime(dt, utc=True, errors="coerce").floor("D")
                except Exception:
                    date = pd.NaT
                val = _extract_defillama_usd_value(r)
                if pd.notna(date) and pd.notna(val):
                    rows.append({"date": date, "defillama_chain": chain, "stablecoin_mcap_usd": val})
            if rows:
                break
        except Exception as e:
            last_error = e
            continue
    if not rows:
        if last_error is not None:
            if getattr(CFG, "verbose_download_logs", False):
                print(f"[defillama] unavailable {chain}: {last_error}")
        else:
            if getattr(CFG, "verbose_download_logs", False):
                print(f"[defillama] unavailable {chain}: empty response")
        return pd.DataFrame(columns=["date", "defillama_chain", "stablecoin_mcap_usd"])
    out = pd.DataFrame(rows).drop_duplicates(["date", "defillama_chain"]).sort_values("date").reset_index(drop=True)
    save_cache(cpath, out.assign(date=out["date"].astype(str)).to_dict(orient="records"))
    return out


def build_defillama_chain_stablecoin_panel(asset_symbols: List[str], cfg: Config) -> pd.DataFrame:
    """Build an asset-chain-day panel of stablecoin settlement capacity from DefiLlama."""
    frames = []
    seen_chains = {}
    for sym in asset_symbols:
        chain = DEFI_LLAMA_CHAIN_MAP.get(sym)
        if not chain:
            continue
        if chain not in seen_chains:
            seen_chains[chain] = fetch_defillama_stablecoin_chart(chain, cfg)
            time.sleep(cfg.sleep_sec)
        df = seen_chains[chain]
        if df is None or df.empty:
            continue
        z = df.copy()
        z["symbol"] = sym
        z["defillama_chain"] = chain
        frames.append(z[["date", "symbol", "defillama_chain", "stablecoin_mcap_usd"]])
    if not frames:
        return pd.DataFrame(columns=["date", "symbol", "defillama_chain", "stablecoin_mcap_usd"])
    return pd.concat(frames, ignore_index=True)


def augment_exposure_with_defillama_stable_metrics(exposure: pd.DataFrame, price_panel: pd.DataFrame, dl_panel: pd.DataFrame, cfg: Config) -> pd.DataFrame:
    """Add free DefiLlama chain-stablecoin supply proxies to the exposure table."""
    out = exposure.copy()
    if out.empty:
        return out
    metric_rows = []
    for _, r in out.iterrows():
        sym = r["symbol"]
        t = utc(r["event_date"]).floor("D") if "event_date" in r else utc(r["objective_window_end"]).floor("D")
        pre_end = utc(r.get("objective_window_end", t - pd.Timedelta(days=cfg.objective_gap_days))).floor("D")
        pre_start = utc(r.get("objective_window_start", pre_end - pd.Timedelta(days=cfg.objective_pre_days - 1))).floor("D")
        chain = DEFI_LLAMA_CHAIN_MAP.get(sym)
        dz = dl_panel[(dl_panel["symbol"] == sym) & (dl_panel["date"] >= pre_start) & (dl_panel["date"] <= pre_end)].copy() if dl_panel is not None and not dl_panel.empty else pd.DataFrame()
        mean_stable = dz["stablecoin_mcap_usd"].mean() if not dz.empty else np.nan
        valid = dz.sort_values("date")["stablecoin_mcap_usd"].dropna() if not dz.empty else pd.Series(dtype=float)
        first_stable = valid.iloc[0] if len(valid) else np.nan
        last_stable = valid.iloc[-1] if len(valid) else np.nan
        change = np.nan if pd.isna(first_stable) or first_stable <= 0 or pd.isna(last_stable) else last_stable / first_stable - 1.0
        mean_mcap = r.get("mean_mcap_90d", np.nan)
        ratio = np.nan if pd.isna(mean_stable) or pd.isna(mean_mcap) or mean_mcap <= 0 else mean_stable / mean_mcap
        metric_rows.append({
            "event_id": r["event_id"], "symbol": sym,
            "defillama_chain": chain,
            "dl_stablecoin_mcap_mean_90d": mean_stable,
            "dl_stablecoin_mcap_ratio_90d": ratio,
            "dl_stablecoin_mcap_change_90d": change,
            "dl_stablecoin_obs_days_90d": int(len(dz)) if not dz.empty else 0,
            "dl_settlement_proxy_note": "chain stablecoin supply / token market cap; settlement-capacity proxy, not transfer volume" if chain else "not chain-mapped asset",
        })
    metr = pd.DataFrame(metric_rows)
    out = out.merge(metr, on=["event_id", "symbol"], how="left")
    out["log_dl_stablecoin_mcap_ratio_90d"] = np.log1p(pd.to_numeric(out["dl_stablecoin_mcap_ratio_90d"], errors="coerce").clip(lower=0))
    out["log_dl_stablecoin_mcap_mean_90d"] = np.log1p(pd.to_numeric(out["dl_stablecoin_mcap_mean_90d"], errors="coerce").clip(lower=0))
    out["dl_stablecoin_mcap_change_90d_winsor"] = out.groupby("event_id")["dl_stablecoin_mcap_change_90d"].transform(lambda s: winsorize_series(s, 0.02, 0.98))
    for c in ["log_dl_stablecoin_mcap_ratio_90d", "log_dl_stablecoin_mcap_mean_90d", "dl_stablecoin_mcap_change_90d_winsor"]:
        out[c + "_z"] = out.groupby("event_id")[c].transform(zscore)
    out["objective_settlement_capacity_z"] = out["log_dl_stablecoin_mcap_ratio_90d_z"]
    out["objective_settlement_growth_z"] = out["dl_stablecoin_mcap_change_90d_winsor_z"]
    turn_col = "log_cg_exchange_turnover_mcap_90d_z"

    # Full-sample fallback retained only as a diagnostic/appendix-style variable:
    # if settlement capacity is missing, pandas skips the missing value and the
    # measure reduces to standardized turnover. This is NOT the baseline hybrid.
    out["objective_tradable_settlement_fullsample_z"] = out[[turn_col, "objective_settlement_capacity_z"]].mean(axis=1, skipna=True)

    # Baseline mapped-sample hybrid:
    # defined only for assets with both turnover and DefiLlama settlement-capacity data.
    # Unmapped assets remain NaN here and are therefore excluded from hybrid regressions.
    out["objective_tradable_settlement_z"] = np.where(
        out[turn_col].notna() & out["objective_settlement_capacity_z"].notna(),
        0.5 * (out[turn_col] + out["objective_settlement_capacity_z"]),
        np.nan,
    )

    out["_turnover_x_settlement_raw"] = out[turn_col] * out["objective_settlement_capacity_z"]
    out["objective_turnover_x_settlement_z"] = out.groupby("event_id")["_turnover_x_settlement_raw"].transform(zscore)
    out = out.drop(columns=["_turnover_x_settlement_raw"], errors="ignore")
    return out


