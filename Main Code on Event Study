def build_events(raw_list: List[dict], cfg: Config) -> pd.DataFrame:
    df = pd.DataFrame(raw_list).copy()
    df["event_date"] = pd.to_datetime(df["event_date"], utc=True)
    for col, default in [("car_post_days", cfg.default_event_car_days), ("portwatch_window_days", 3), ("stable_window_days", 7), ("peg_window_days", 3)]:
        if col not in df.columns:
            df[col] = default
        df[col] = df[col].fillna(default).astype(int)
    return df.sort_values("event_date").reset_index(drop=True)


