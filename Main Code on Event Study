        "start_time": str(utc(start_dt).date()),
        "end_time": str(utc(end_dt).date()),
        "frequency": "1d",
        "page_size": 10000,
    }
    try:
        data = request_json_with_backoff(url, params=params, timeout=CFG.timeout_sec, max_retries=3)
    except Exception as e:
        # Some assets/metrics are not in Community API. Return empty and let the model use fallback variables.
        if getattr(CFG, "verbose_download_logs", False):
            print(f"[coinmetrics] unavailable {cm_asset}: {e}")
